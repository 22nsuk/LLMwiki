      },
      "role": "auto-improve-readiness-report-body-worktree-guard-refresh"
    },
    {
      "target": "release-run-ready-plan-check",
      "required_assignments": {
        "RELEASE_CLOSEOUT_DISTRIBUTION_ZIP": "$(RELEASE_AUTO_PROMOTION_EFFECTIVE_DISTRIBUTION_ZIP)"
      },
      "role": "release-run-ready-plan-check-auto-promotion-distribution"
