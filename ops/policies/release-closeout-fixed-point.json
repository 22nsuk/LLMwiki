{
  "version": 5,
  "max_iterations": 10,
  "feedback_refresh_targets": [
    "generated-artifact-index-body",
    "artifact-freshness",
    "external-report-action-matrix"
  ],
  "cost_trend": {
    "retained_run_count": 10,
    "thresholds": {
      "default": {
        "min_previous_samples": 1,
        "total_duration_ms_attention": 120000,
        "max_duration_ms_attention": 90000,
        "relative_total_duration_attention_multiplier": 3.0,
        "minimum_relative_delta_ms": 5000
      },
      "writers": {}
    }
  },
  "writers": [
    {
      "name": "goal-worktree-guard",
      "target": "auto-improve-readiness-worktree-guard",
      "produces": ["ops/reports/goal-worktree-guard.json"],
      "depends_on": [],
      "expensive_prerequisites_once": []
    },
    {
      "name": "generated-artifact-index",
      "target": "generated-artifact-index-body",
      "produces": ["ops/reports/generated-artifact-index.json"],
      "depends_on": ["auto-improve-readiness-worktree-guard"],
      "expensive_prerequisites_once": [
        "closure-registry-envelope",
        "manual-mutate-defect-registry",
        "release-risk-taxonomy-matrix"
      ]
    },
    {
      "name": "artifact-freshness",
      "target": "artifact-freshness",
      "produces": ["ops/reports/artifact-freshness-report.json"],
      "depends_on": ["generated-artifact-index-body"],
      "expensive_prerequisites_once": []
    },
    {
      "name": "external-report-action-matrix",
      "target": "external-report-action-matrix",
      "produces": ["ops/reports/external-report-action-matrix.json"],
      "depends_on": ["artifact-freshness"],
      "expensive_prerequisites_once": []
    },
    {
      "name": "auto-improve-readiness",
      "target": "auto-improve-readiness-report-body",
      "produces": ["ops/reports/auto-improve-readiness.json"],
      "depends_on": ["auto-improve-readiness-worktree-guard", "artifact-freshness"],
      "expensive_prerequisites_once": []
    },
    {
      "name": "release-closeout-summary",
      "target": "release-closeout-summary-report",
      "produces": ["ops/reports/release-closeout-summary.json"],
      "depends_on": [
        "generated-artifact-index-body",
        "artifact-freshness",
        "auto-improve-readiness-report-body"
      ],
      "expensive_prerequisites_once": []
    },
    {
      "name": "learning-readiness-signoff-revalidation",
      "target": "learning-readiness-signoff-revalidation",
      "produces": ["ops/reports/learning-readiness-signoff-revalidation.json"],
      "depends_on": ["release-closeout-summary-report", "artifact-freshness"],
      "expensive_prerequisites_once": []
    },
    {
      "name": "release-evidence-cohort",
      "target": "release-evidence-cohort",
      "produces": ["ops/reports/release-evidence-cohort.json"],
      "depends_on": [
        "release-closeout-summary-report",
        "learning-readiness-signoff-revalidation",
        "artifact-freshness"
      ],
      "expensive_prerequisites_once": []
    },
    {
      "name": "release-evidence-dashboard",
      "target": "release-evidence-dashboard-report",
      "produces": ["ops/reports/release-evidence-dashboard.json"],
      "depends_on": [
        "release-closeout-summary-report",
        "learning-readiness-signoff-revalidation",
        "release-evidence-cohort",
        "artifact-freshness"
      ],
      "expensive_prerequisites_once": []
    },
    {
      "name": "release-lane-summary",
      "target": "release-lane-summary",
      "produces": ["ops/reports/release-lane-summary.json"],
      "depends_on": [
        "release-closeout-summary-report",
        "release-evidence-dashboard-report",
        "release-evidence-cohort"
      ],
      "expensive_prerequisites_once": []
    },
    {
      "name": "release-clean-blocker-ledger",
      "target": "release-clean-blocker-ledger",
      "produces": ["ops/reports/release-clean-blocker-ledger.json"],
      "depends_on": [
        "release-closeout-summary-report",
        "release-evidence-dashboard-report",
        "release-lane-summary",
        "release-evidence-cohort"
      ],
      "expensive_prerequisites_once": []
    },
    {
      "name": "release-closeout-batch-manifest",
      "target": "release-closeout-batch-manifest-promote",
      "produces": ["ops/reports/release-closeout-batch-manifest.json"],
      "depends_on": [
        "generated-artifact-index-body",
        "artifact-freshness",
        "release-closeout-summary-report",
        "learning-readiness-signoff-revalidation",
        "release-evidence-cohort",
        "release-evidence-dashboard-report",
        "release-lane-summary",
        "release-clean-blocker-ledger"
      ],
      "expensive_prerequisites_once": []
    },
    {
      "name": "release-evidence-closeout-self-check",
      "target": "release-evidence-closeout-self-check",
      "produces": ["ops/reports/release-evidence-closeout-self-check.json"],
      "depends_on": ["release-closeout-batch-manifest-promote"],
      "expensive_prerequisites_once": []
    }
  ],
  "tracked_artifacts": [
    "ops/reports/goal-worktree-guard.json",
    "ops/reports/generated-artifact-index.json",
    "ops/reports/artifact-freshness-report.json",
    "ops/reports/external-report-action-matrix.json",
    "ops/reports/auto-improve-readiness.json",
    "ops/reports/release-closeout-summary.json",
    "ops/reports/learning-readiness-signoff-revalidation.json",
    "ops/reports/release-evidence-cohort.json",
    "ops/reports/release-evidence-dashboard.json",
    "ops/reports/release-lane-summary.json",
    "ops/reports/release-clean-blocker-ledger.json",
    "ops/reports/release-closeout-batch-manifest.json",
    "ops/reports/release-evidence-closeout-self-check.json"
  ]
}
