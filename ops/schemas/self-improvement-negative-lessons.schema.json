{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LLM Wiki Self Improvement Negative Lessons",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "artifact_kind",
    "generated_at",
    "producer",
    "status",
    "source_activation_report",
    "summary",
    "patterns"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "enum": ["ops/schemas/self-improvement-negative-lessons.schema.json"]
    },
    "artifact_kind": {
      "type": "string",
      "enum": ["self_improvement_negative_lessons"]
    },
    "schema_version": { "type": "integer", "minimum": 1 },
    "generated_at": { "type": "string", "minLength": 1 },
    "producer": { "type": "string", "minLength": 1 },
    "source_command": { "type": "string", "minLength": 1 },
    "source_revision": { "type": "string", "minLength": 1 },
    "source_tree_fingerprint": { "type": "string", "minLength": 1 },
    "input_fingerprints": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "artifact_status": {
      "type": "string",
      "enum": ["current", "archived", "stale", "unknown"]
    },
    "retention_policy": {
      "type": "string",
      "enum": ["ephemeral", "canonical_report", "archive"]
    },
    "encoding": { "type": "string", "enum": ["utf-8"] },
    "currentness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "checked_at"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["current", "stale", "unknown", "invalid"]
        },
        "checked_at": { "type": "string", "minLength": 1 }
      }
    },
    "status": { "type": "string", "enum": ["pass", "attention"] },
    "source_activation_report": { "type": "string" },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pattern_count", "gate_effect"],
      "properties": {
        "pattern_count": { "type": "integer", "minimum": 0 },
        "gate_effect": { "type": "string", "enum": ["none"] }
      }
    },
    "patterns": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "status"],
        "properties": {
          "id": { "type": "string" },
          "status": { "type": "string" }
        }
      }
    }
  }
}
