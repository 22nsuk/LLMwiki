{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llmwiki.local/schemas/self-improvement-negative-lessons.schema.json",
  "title": "Self-improvement negative lessons report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "artifact_kind",
    "generated_at",
    "producer",
    "source_command",
    "source_revision",
    "source_tree_fingerprint",
    "input_fingerprints",
    "schema_version",
    "artifact_status",
    "retention_policy",
    "encoding",
    "currentness",
    "vault",
    "policy",
    "status",
    "mode",
    "gate_effect",
    "summary",
    "lessons",
    "inputs"
  ],
  "properties": {
    "$schema": { "type": "string", "const": "ops/schemas/self-improvement-negative-lessons.schema.json" },
    "artifact_kind": { "type": "string", "const": "self_improvement_negative_lessons" },
    "generated_at": { "type": "string", "minLength": 1 },
    "producer": { "type": "string", "const": "ops.scripts.self_improvement_negative_lessons" },
    "source_command": { "type": "string", "minLength": 1 },
    "source_revision": { "type": "string" },
    "source_tree_fingerprint": { "type": "string", "minLength": 1 },
    "input_fingerprints": { "type": "object" },
    "schema_version": { "type": "integer", "const": 1 },
    "artifact_status": { "type": "string" },
    "retention_policy": { "type": "string" },
    "encoding": { "type": "string", "const": "utf-8" },
    "currentness": { "type": "object" },
    "vault": { "type": "string" },
    "policy": { "$ref": "#/$defs/policy" },
    "status": { "type": "string", "enum": ["pass", "attention"] },
    "mode": { "type": "string", "const": "advisory" },
    "gate_effect": { "type": "string", "const": "blocks_repeat_only" },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lesson_count",
        "backlog_candidate_count",
        "source_activation_status",
        "next_action"
      ],
      "properties": {
        "lesson_count": { "type": "integer", "minimum": 0 },
        "backlog_candidate_count": { "type": "integer", "minimum": 0 },
        "source_activation_status": { "type": "string" },
        "next_action": { "type": "string", "minLength": 1 }
      }
    },
    "lessons": {
      "type": "array",
      "items": { "$ref": "#/$defs/lesson" }
    },
    "inputs": { "$ref": "#/$defs/inputs" }
  },
  "$defs": {
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "version"],
      "properties": {
        "path": { "type": "string" },
        "version": { "type": ["integer", "string", "null"] }
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["learning_claim_activation", "session_synopsis"],
      "properties": {
        "learning_claim_activation": { "type": "string", "minLength": 1 },
        "session_synopsis": { "type": "string", "minLength": 1 }
      }
    },
    "evidence_digest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "exists", "sha256", "status"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "exists": { "type": "boolean" },
        "sha256": { "type": "string" },
        "status": { "type": "string", "minLength": 1 }
      }
    },
    "lesson": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lesson_id",
        "source",
        "decisions",
        "run_ids",
        "occurrence_count",
        "forbidden_repeat",
        "repair_target",
        "evidence_digests",
        "repeat_policy",
        "backlog_candidate"
      ],
      "properties": {
        "lesson_id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
        "source": { "type": "string", "minLength": 1 },
        "decisions": {
          "type": "array",
          "items": { "type": "string", "enum": ["HOLD", "DISCARD", "BLOCKED"] }
        },
        "run_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "occurrence_count": { "type": "integer", "minimum": 1 },
        "forbidden_repeat": { "type": "string" },
        "repair_target": { "type": "string" },
        "evidence_digests": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence_digest" }
        },
        "repeat_policy": { "type": "string", "const": "do_not_repeat_until_repaired" },
        "backlog_candidate": { "type": "boolean" }
      }
    }
  }
}
