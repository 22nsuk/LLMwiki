{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llmwiki.local/schemas/goal-run-status.schema.json",
  "title": "Goal run status report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "artifact_kind",
    "generated_at",
    "producer",
    "source_command",
    "source_revision",
    "source_tree_fingerprint",
    "input_fingerprints",
    "schema_version",
    "artifact_status",
    "retention_policy",
    "encoding",
    "currentness",
    "goal",
    "run",
    "observability",
    "health",
    "runtime_certificate",
    "periodic_evidence",
    "session_synopsis",
    "auto_improve_session",
    "artifacts",
    "promotion_guard",
    "blockers",
    "status"
  ],
  "properties": {
    "$schema": { "type": "string", "const": "ops/schemas/goal-run-status.schema.json" },
    "artifact_kind": { "type": "string", "const": "goal_run_status" },
    "generated_at": { "type": "string", "minLength": 1 },
    "producer": { "type": "string", "const": "ops.scripts.goal_run_status" },
    "source_command": { "type": "string", "minLength": 1 },
    "source_revision": { "type": "string" },
    "source_tree_fingerprint": { "type": "string", "minLength": 1 },
    "input_fingerprints": { "type": "object" },
    "schema_version": { "type": "integer", "const": 1 },
    "artifact_status": { "type": "string" },
    "retention_policy": { "type": "string" },
    "encoding": { "type": "string", "const": "utf-8" },
    "currentness": { "type": "object" },
    "completion_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "completion_class",
        "stop_reason",
        "completion_status",
        "promotion_lane",
        "promotion_lane_label",
        "headline"
      ],
      "properties": {
        "completion_class": { "type": "string" },
        "stop_reason": { "type": "string" },
        "completion_status": {
          "type": "string",
          "enum": ["bounded_success", "stopped", "not_available"]
        },
        "promotion_lane": { "type": "string" },
        "promotion_lane_label": { "type": "string" },
        "headline": { "type": "string", "minLength": 1 }
      }
    },
    "goal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_path",
        "contract_sha256",
        "contract_status",
        "contract_id",
        "objective",
        "goal_status",
        "backend"
      ],
      "properties": {
        "contract_path": { "type": "string", "minLength": 1 },
        "contract_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "contract_status": { "type": "string", "enum": ["loaded"] },
        "contract_id": { "type": "string", "minLength": 1 },
        "objective": { "type": "string", "minLength": 1 },
        "goal_status": {
          "type": "string",
          "enum": ["active", "paused", "completed", "failed", "stopped"]
        },
        "backend": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "process_persistent"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "process_persistent": { "type": "boolean", "const": true }
          }
        }
      }
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "status",
        "runtime_mode",
        "started_at",
        "updated_at"
      ],
      "properties": {
        "run_id": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": ["running", "paused", "completed", "failed", "stopped", "blocked"]
        },
        "runtime_mode": {
          "type": "string",
          "enum": ["self_improvement_loop"]
        },
        "started_at": { "type": "string", "minLength": 1 },
        "updated_at": { "type": "string", "minLength": 1 },
        "completed_at": { "type": "string" }
      }
    },
    "observability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "heartbeat_interval_seconds",
        "checkpoint_interval_seconds",
        "last_heartbeat_at",
        "last_checkpoint_at",
        "last_command_heartbeat_at",
        "quiet_seconds",
        "command_observation_mode",
        "command_heartbeat_count",
        "command_timeout_seconds",
        "last_stdout_at",
        "last_stderr_at",
        "last_artifact_touch_at",
        "last_command_returncode",
        "last_command_timed_out",
        "last_command_termination_reason",
        "last_backoff_until",
        "backoff_reason",
        "resume_from_checkpoint",
        "resume_command"
      ],
      "properties": {
        "heartbeat_interval_seconds": { "type": "integer", "minimum": 1 },
        "checkpoint_interval_seconds": { "type": "integer", "minimum": 1 },
        "last_heartbeat_at": { "type": "string" },
        "last_checkpoint_at": { "type": "string" },
        "last_command_heartbeat_at": { "type": "string" },
        "quiet_seconds": { "type": "integer", "minimum": 0 },
        "command_observation_mode": {
          "type": "string",
          "enum": ["", "communicate", "process_heartbeat", "process_poll"]
        },
        "command_heartbeat_count": { "type": "integer", "minimum": 0 },
        "command_timeout_seconds": { "type": "integer", "minimum": 0 },
        "last_stdout_at": { "type": "string" },
        "last_stderr_at": { "type": "string" },
        "last_artifact_touch_at": { "type": "string" },
        "last_command_returncode": { "type": "integer" },
        "last_command_timed_out": { "type": "boolean" },
        "last_command_termination_reason": { "type": "string" },
        "last_backoff_until": { "type": "string" },
        "backoff_reason": { "type": "string" },
        "resume_from_checkpoint": { "type": "boolean" },
        "resume_command": { "type": "string" }
      }
    },
    "health": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "heartbeat_status",
        "checkpoint_status",
        "command_heartbeat_status",
        "backoff_status",
        "resume_status",
        "promotion_status",
        "can_promote_result"
      ],
      "properties": {
        "heartbeat_status": {
          "type": "string",
          "enum": ["current", "stale", "unknown", "not_recorded"]
        },
        "checkpoint_status": {
          "type": "string",
          "enum": ["current", "stale", "unknown", "not_recorded"]
        },
        "command_heartbeat_status": {
          "type": "string",
          "enum": ["current", "stale", "unknown", "not_recorded"]
        },
        "backoff_status": {
          "type": "string",
          "enum": ["inactive", "active", "expired", "unknown"]
        },
        "resume_status": {
          "type": "string",
          "enum": ["not_requested", "ready", "missing_resume_command"]
        },
        "promotion_status": {
          "type": "string",
          "enum": ["blocked", "allowed"]
        },
        "can_promote_result": { "type": "boolean" }
      }
    },
    "runtime_certificate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "mode",
        "run_mode",
        "duration_seconds",
        "certificate_status",
        "mode_consistent",
        "full_gate_clean",
        "can_promote_result",
        "sealed_authority_clean",
        "promotion_blockers",
        "required_evidence",
        "missing_evidence"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pending", "complete", "inconsistent"]
        },
        "mode": {
          "type": "string",
          "enum": ["self_improvement_loop"]
        },
        "run_mode": {
          "type": "string",
          "enum": ["self_improvement_loop"]
        },
        "duration_seconds": { "type": "integer", "minimum": 1 },
        "certificate_status": {
          "type": "string",
          "enum": ["unverified", "verified"]
        },
        "mode_consistent": { "type": "boolean" },
        "full_gate_clean": { "type": "boolean" },
        "can_promote_result": { "type": "boolean" },
        "sealed_authority_clean": { "type": "boolean" },
        "promotion_blockers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "required_evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence_path_status" }
        },
        "missing_evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence_path_status" }
        }
      }
    },
    "periodic_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "schedule",
        "observed_checkpoint_count",
        "due_checkpoint_count",
        "missing_due_checkpoint_ids",
        "next_checkpoint_id",
        "checkpoints"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["not_due", "current", "missing_due_evidence"]
        },
        "schedule": {
          "type": "string",
          "const": "6h_12h_24h"
        },
        "observed_checkpoint_count": { "type": "integer", "minimum": 0 },
        "due_checkpoint_count": { "type": "integer", "minimum": 0 },
        "missing_due_checkpoint_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "next_checkpoint_id": { "type": "string" },
        "checkpoints": {
          "type": "array",
          "items": { "$ref": "#/$defs/periodic_evidence_checkpoint" },
          "minItems": 3
        }
      }
    },
    "session_synopsis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "link_status",
        "report_path",
        "status",
        "generated_at",
        "recent_blocker_count",
        "evidence_gap_count",
        "next_action"
      ],
      "properties": {
        "link_status": {
          "type": "string",
          "enum": ["linked", "missing"]
        },
        "report_path": { "type": "string", "minLength": 1 },
        "status": { "type": "string" },
        "generated_at": { "type": "string" },
        "recent_blocker_count": { "type": "integer", "minimum": 0 },
        "evidence_gap_count": { "type": "integer", "minimum": 0 },
        "next_action": { "type": "string" }
      }
    },
    "auto_improve_session": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "link_status",
        "report_path",
        "status",
        "generated_at",
        "stop_reason",
        "completion_class",
        "iteration_count",
        "promoted_iteration_count"
      ],
      "properties": {
        "link_status": {
          "type": "string",
          "enum": ["linked", "missing"]
        },
        "report_path": { "type": "string" },
        "status": { "type": "string" },
        "generated_at": { "type": "string" },
        "stop_reason": { "type": "string" },
        "completion_class": { "type": "string" },
        "promotion_lane": { "type": "string" },
        "promotion_lane_label": { "type": "string" },
        "iteration_count": { "type": "integer", "minimum": 0 },
        "promoted_iteration_count": { "type": "integer", "minimum": 0 }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status_report_path",
        "status_markdown_path",
        "audit_log_path",
        "resume_metadata_path",
        "checkpoint_command_log_path"
      ],
      "properties": {
        "status_report_path": { "type": "string", "minLength": 1 },
        "status_markdown_path": { "type": "string", "minLength": 1 },
        "audit_log_path": { "type": "string", "minLength": 1 },
        "resume_metadata_path": { "type": "string", "minLength": 1 },
        "checkpoint_command_log_path": { "type": "string", "minLength": 1 }
      }
    },
    "promotion_guard": { "type": "object" },
    "blockers": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "status": {
      "type": "string",
      "enum": ["pass", "attention", "fail"]
    }
  },
  "$defs": {
    "periodic_evidence_checkpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checkpoint_id",
        "due_after_seconds",
        "due_at",
        "due",
        "status",
        "commands",
        "command_run",
        "evidence_paths"
      ],
      "properties": {
        "checkpoint_id": {
          "type": "string",
          "enum": ["checkpoint_6h", "checkpoint_12h", "checkpoint_24h"]
        },
        "due_after_seconds": { "type": "integer", "minimum": 1 },
        "due_at": { "type": "string" },
        "due": { "type": "boolean" },
        "status": {
          "type": "string",
          "enum": ["pending", "observed", "missing"]
        },
        "commands": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "command_run": { "$ref": "#/$defs/checkpoint_command_run" },
        "evidence_paths": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence_path_status" },
          "minItems": 1
        }
      }
    },
    "checkpoint_command_run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "last_event_at",
        "command_count",
        "failed_command_count",
        "log_path"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["not_due", "not_run", "pass", "fail"]
        },
        "last_event_at": { "type": "string" },
        "command_count": { "type": "integer", "minimum": 0 },
        "failed_command_count": { "type": "integer", "minimum": 0 },
        "log_path": { "type": "string" }
      }
    },
    "evidence_path_status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "status"],
      "properties": {
        "evidence_id": { "type": "string" },
        "path": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": ["present", "missing"]
        },
        "report_status": { "type": "string", "minLength": 1 },
        "preflight_status": { "type": "string", "minLength": 1 },
        "distribution_binding_status": { "type": "string", "minLength": 1 },
        "authority_preflight_status": { "type": "string", "minLength": 1 },
        "generated_at": { "type": "string" },
        "freshness_status": {
          "type": "string",
          "enum": ["not_due", "fresh", "stale", "missing"]
        }
      }
    }
  }
}
