{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llmwiki.local/schemas/release-closeout-fixed-point.schema.json",
  "title": "Release closeout single-pass graph report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "artifact_kind",
    "generated_at",
    "producer",
    "source_command",
    "source_revision",
    "source_tree_fingerprint",
    "input_fingerprints",
    "schema_version",
    "artifact_status",
    "retention_policy",
    "encoding",
    "currentness",
    "vault",
    "policy",
    "status",
    "execution_pass_count",
    "tracked_artifacts",
    "command_sequence",
    "execution",
    "raw_digest_map",
    "binding_digest_map",
    "binding_mode_map",
    "duration_summary"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "ops/schemas/release-closeout-fixed-point.schema.json"
    },
    "artifact_kind": {
      "type": "string",
      "const": "release_closeout_fixed_point_report"
    },
    "generated_at": { "type": "string", "minLength": 1 },
    "producer": {
      "type": "string",
      "const": "ops.scripts.release_closeout_fixed_point"
    },
    "source_command": { "type": "string", "minLength": 1 },
    "source_revision": { "type": "string" },
    "source_tree_fingerprint": { "type": "string", "minLength": 1 },
    "input_fingerprints": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "schema_version": { "type": "integer", "const": 2 },
    "artifact_status": {
      "type": "string",
      "enum": ["current", "stale"]
    },
    "retention_policy": { "type": "string", "minLength": 1 },
    "encoding": { "type": "string", "const": "utf-8" },
    "currentness": {
      "type": "object",
      "additionalProperties": true,
      "required": ["status", "checked_at"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["current", "stale", "unknown"]
        },
        "checked_at": { "type": "string", "minLength": 1 }
      }
    },
    "vault": { "type": "string", "minLength": 1 },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "version"],
      "properties": {
        "path": {
          "type": "string",
          "const": "ops/policies/release-closeout-fixed-point.json"
        },
        "version": { "type": "integer", "minimum": 1 }
      }
    },
    "status": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "execution_pass_count": { "type": "integer", "const": 1 },
    "tracked_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/trackedArtifact" }
    },
    "command_sequence": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "execution": { "$ref": "#/$defs/execution" },
    "raw_digest_map": { "$ref": "#/$defs/digestMap" },
    "binding_digest_map": { "$ref": "#/$defs/digestMap" },
    "binding_mode_map": { "$ref": "#/$defs/bindingModeMap" },
    "duration_summary": { "$ref": "#/$defs/durationSummary" }
  },
  "$defs": {
    "digestMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^(missing|[0-9a-f]{64})$"
      }
    },
    "bindingModeMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "enum": ["content", "revision"]
      }
    },
    "trackedArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "path", "binding_mode"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "binding_mode": {
          "type": "string",
          "enum": ["content", "revision"]
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "reason",
        "selected_targets",
        "command_results",
        "raw_digest_map",
        "raw_digest_changed",
        "raw_changed_paths",
        "binding_digest_map",
        "binding_mode_map",
        "binding_changed_paths"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pass", "fail"]
        },
        "reason": { "type": "string", "minLength": 1 },
        "selected_targets": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "command_results": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/commandResult" }
        },
        "raw_digest_map": { "$ref": "#/$defs/digestMap" },
        "raw_digest_changed": { "type": "boolean" },
        "raw_changed_paths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "binding_digest_map": { "$ref": "#/$defs/digestMap" },
        "binding_mode_map": { "$ref": "#/$defs/bindingModeMap" },
        "binding_changed_paths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "status": { "const": "pass" } },
            "required": ["status"]
          },
          "then": {
            "properties": {
              "reason": { "const": "single_topological_pass_completed" }
            }
          }
        }
      ]
    },
    "commandResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target",
        "command",
        "returncode",
        "timed_out",
        "timeout_seconds",
        "termination_reason",
        "duration_ms",
        "stdout_tail",
        "stderr_tail",
        "status",
        "tracked_paths_changed",
        "undeclared_tracked_writes",
        "issues"
      ],
      "properties": {
        "target": { "type": "string", "minLength": 1 },
        "command": {
          "type": "array",
          "items": { "type": "string" }
        },
        "returncode": { "type": "integer" },
        "timed_out": { "type": "boolean" },
        "timeout_seconds": { "type": "integer", "minimum": 1 },
        "termination_reason": { "type": "string" },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "stdout_tail": { "type": "string" },
        "stderr_tail": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["pass", "fail"]
        },
        "tracked_paths_changed": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "undeclared_tracked_writes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "issues": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["undeclared_tracked_write"]
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "status": { "const": "pass" } },
            "required": ["status"]
          },
          "then": {
            "properties": {
              "timed_out": { "const": false },
              "undeclared_tracked_writes": { "maxItems": 0 },
              "issues": { "maxItems": 0 }
            }
          }
        }
      ]
    },
    "durationSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "execution_pass_count",
        "command_run_count",
        "total_duration_ms",
        "writer_costs",
        "expensive_prerequisites",
        "summary"
      ],
      "properties": {
        "execution_pass_count": { "type": "integer", "const": 1 },
        "command_run_count": { "type": "integer", "minimum": 1 },
        "total_duration_ms": { "type": "integer", "minimum": 0 },
        "writer_costs": {
          "type": "array",
          "items": { "$ref": "#/$defs/writerCost" }
        },
        "expensive_prerequisites": {
          "$ref": "#/$defs/expensivePrerequisites"
        },
        "summary": { "type": "string", "minLength": 1 }
      }
    },
    "writerCost": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "target",
        "produces",
        "run_count",
        "selected",
        "total_duration_ms",
        "average_duration_ms",
        "max_duration_ms"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 },
        "produces": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "run_count": { "type": "integer", "minimum": 0, "maximum": 1 },
        "selected": { "type": "boolean" },
        "total_duration_ms": { "type": "integer", "minimum": 0 },
        "average_duration_ms": { "type": "integer", "minimum": 0 },
        "max_duration_ms": { "type": "integer", "minimum": 0 }
      }
    },
    "expensivePrerequisites": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "targets",
        "configured_target_count",
        "observed_target_count",
        "run_count",
        "total_duration_ms",
        "summary"
      ],
      "properties": {
        "targets": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "configured_target_count": { "type": "integer", "minimum": 0 },
        "observed_target_count": { "type": "integer", "minimum": 0 },
        "run_count": { "type": "integer", "minimum": 0 },
        "total_duration_ms": { "type": "integer", "minimum": 0 },
        "summary": { "type": "string", "minLength": 1 }
      }
    }
  }
}
