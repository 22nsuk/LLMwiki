{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llmwiki.local/schemas/release-closeout-fixed-point-cost-trend.schema.json",
  "title": "Release closeout fixed-point cost trend",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "artifact_kind",
    "generated_at",
    "producer",
    "source_command",
    "source_revision",
    "source_tree_fingerprint",
    "input_fingerprints",
    "schema_version",
    "artifact_status",
    "retention_policy",
    "encoding",
    "currentness",
    "vault",
    "policy",
    "status",
    "retained_run_count",
    "sample_count",
    "previous_trend",
    "latest_sample",
    "samples",
    "writer_trends",
    "threshold_policy",
    "threshold_summary"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "ops/schemas/release-closeout-fixed-point-cost-trend.schema.json"
    },
    "artifact_kind": {
      "type": "string",
      "const": "release_closeout_fixed_point_cost_trend"
    },
    "generated_at": { "type": "string", "minLength": 1 },
    "producer": {
      "type": "string",
      "const": "ops.scripts.release_closeout_fixed_point_cost_trend"
    },
    "source_command": { "type": "string", "minLength": 1 },
    "source_revision": { "type": "string" },
    "source_tree_fingerprint": { "type": "string", "minLength": 1 },
    "input_fingerprints": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "schema_version": { "type": "integer", "minimum": 1 },
    "artifact_status": {
      "type": "string",
      "enum": ["current", "stale"]
    },
    "retention_policy": { "type": "string", "minLength": 1 },
    "encoding": { "type": "string", "const": "utf-8" },
    "currentness": {
      "type": "object",
      "additionalProperties": true,
      "required": ["status", "checked_at"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["current", "stale", "unknown"]
        },
        "checked_at": { "type": "string", "minLength": 1 }
      }
    },
    "vault": { "type": "string", "minLength": 1 },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "version"],
      "properties": {
        "path": {
          "type": "string",
          "const": "ops/policies/release-closeout-fixed-point.json"
        },
        "version": { "type": "integer", "minimum": 1 }
      }
    },
    "status": { "type": "string", "enum": ["pass", "attention"] },
    "retained_run_count": { "type": "integer", "minimum": 1 },
    "sample_count": { "type": "integer", "minimum": 1 },
    "previous_trend": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "load_status", "digest"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "load_status": { "type": "string" },
        "digest": { "$ref": "#/$defs/optionalDigest" }
      }
    },
    "latest_sample": { "$ref": "#/$defs/sample" },
    "samples": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/sample" }
    },
    "writer_trends": {
      "type": "array",
      "items": { "$ref": "#/$defs/writerTrend" }
    },
    "threshold_policy": { "$ref": "#/$defs/thresholdPolicy" },
    "threshold_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "breached_writer_count", "breached_writers", "summary"],
      "properties": {
        "status": { "type": "string", "enum": ["pass", "attention"] },
        "breached_writer_count": { "type": "integer", "minimum": 0 },
        "breached_writers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "summary": { "type": "string", "minLength": 1 }
      }
    }
  },
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "optionalDigest": {
      "type": "string",
      "pattern": "^(|[0-9a-f]{64})$"
    },
    "sample": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fixed_point_report_path",
        "fixed_point_report_digest",
        "fixed_point_generated_at",
        "fixed_point_status",
        "fixed_point_converged",
        "iteration_count",
        "command_run_count",
        "total_duration_ms",
        "writer_costs"
      ],
      "properties": {
        "fixed_point_report_path": { "type": "string", "minLength": 1 },
        "fixed_point_report_digest": { "$ref": "#/$defs/digest" },
        "fixed_point_generated_at": { "type": "string" },
        "fixed_point_status": {
          "type": "string",
          "enum": ["pass", "non_converged", "fail", "unknown"]
        },
        "fixed_point_converged": { "type": "boolean" },
        "iteration_count": { "type": "integer", "minimum": 0 },
        "command_run_count": { "type": "integer", "minimum": 0 },
        "total_duration_ms": { "type": "integer", "minimum": 0 },
        "writer_costs": {
          "type": "array",
          "items": { "$ref": "#/$defs/writerCost" }
        }
      }
    },
    "writerCost": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "target",
        "run_count",
        "total_duration_ms",
        "average_duration_ms",
        "max_duration_ms"
      ],
      "properties": {
        "name": { "type": "string" },
        "target": { "type": "string", "minLength": 1 },
        "run_count": { "type": "integer", "minimum": 0 },
        "total_duration_ms": { "type": "integer", "minimum": 0 },
        "average_duration_ms": { "type": "integer", "minimum": 0 },
        "max_duration_ms": { "type": "integer", "minimum": 0 }
      }
    },
    "writerTrend": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "target",
        "latest_total_duration_ms",
        "latest_average_duration_ms",
        "latest_max_duration_ms",
        "previous_sample_count",
        "previous_average_total_duration_ms",
        "delta_from_previous_average_ms",
        "ratio_to_previous_average",
        "threshold_status",
        "breached_thresholds"
      ],
      "properties": {
        "name": { "type": "string" },
        "target": { "type": "string", "minLength": 1 },
        "latest_total_duration_ms": { "type": "integer", "minimum": 0 },
        "latest_average_duration_ms": { "type": "integer", "minimum": 0 },
        "latest_max_duration_ms": { "type": "integer", "minimum": 0 },
        "previous_sample_count": { "type": "integer", "minimum": 0 },
        "previous_average_total_duration_ms": { "type": "integer", "minimum": 0 },
        "delta_from_previous_average_ms": { "type": "integer" },
        "ratio_to_previous_average": { "type": "number", "minimum": 0 },
        "threshold_status": { "type": "string", "enum": ["pass", "attention"] },
        "breached_thresholds": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "total_duration_ms_attention",
              "max_duration_ms_attention",
              "relative_total_duration_attention_multiplier"
            ]
          }
        }
      }
    },
    "thresholdPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["retained_run_count", "default", "writers"],
      "properties": {
        "retained_run_count": { "type": "integer", "minimum": 1 },
        "default": { "$ref": "#/$defs/thresholdConfig" },
        "writers": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/thresholdConfig" }
        }
      }
    },
    "thresholdConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "min_previous_samples",
        "total_duration_ms_attention",
        "max_duration_ms_attention",
        "relative_total_duration_attention_multiplier",
        "minimum_relative_delta_ms"
      ],
      "properties": {
        "min_previous_samples": { "type": "integer", "minimum": 0 },
        "total_duration_ms_attention": { "type": "integer", "minimum": 0 },
        "max_duration_ms_attention": { "type": "integer", "minimum": 0 },
        "relative_total_duration_attention_multiplier": { "type": "number", "minimum": 0 },
        "minimum_relative_delta_ms": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
