{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Doc Graph Integrity",
  "oneOf": [
    { "$ref": "#/$defs/report" },
    { "$ref": "#/$defs/allowlist" }
  ],
  "$defs": {
    "allowlist": {
      "type": "object",
      "additionalProperties": false,
      "required": ["$schema", "allowed_orphans"],
      "properties": {
        "$schema": { "type": "string", "const": "ops/schemas/doc-graph-integrity.schema.json" },
        "allowed_orphans": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "retained_reason"],
            "properties": {
              "path": { "type": "string", "minLength": 1 },
              "retained_reason": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "report": {
      "type": "object",
      "additionalProperties": false,
      "required": ["$schema", "artifact_kind", "generated_at", "producer", "status", "allowlist_path", "summary", "docs", "missing_links", "orphan_docs", "unallowed_orphans", "stale_allowlist"],
      "properties": {
        "$schema": { "type": "string", "const": "ops/schemas/doc-graph-integrity.schema.json" },
        "artifact_kind": { "type": "string", "const": "doc_graph_integrity" },
        "generated_at": { "type": "string", "minLength": 1 },
        "producer": { "type": "string", "const": "ops.scripts.doc_graph_integrity" },
        "status": { "type": "string", "enum": ["pass", "fail"] },
        "allowlist_path": { "type": "string", "minLength": 1 },
        "summary": {
          "type": "object",
          "additionalProperties": false,
          "required": ["doc_count", "missing_link_count", "orphan_doc_count", "unallowed_orphan_count", "stale_allowlist_count"],
          "properties": {
            "doc_count": { "type": "integer", "minimum": 0 },
            "missing_link_count": { "type": "integer", "minimum": 0 },
            "orphan_doc_count": { "type": "integer", "minimum": 0 },
            "unallowed_orphan_count": { "type": "integer", "minimum": 0 },
            "stale_allowlist_count": { "type": "integer", "minimum": 0 }
          }
        },
        "docs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "missing_links": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source", "target"],
            "properties": {
              "source": { "type": "string", "minLength": 1 },
              "target": { "type": "string", "minLength": 1 }
            }
          }
        },
        "orphan_docs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "unallowed_orphans": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "stale_allowlist": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    }
  }
}
