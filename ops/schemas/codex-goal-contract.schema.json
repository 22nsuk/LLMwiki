{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llmwiki.local/schemas/codex-goal-contract.schema.json",
  "title": "Codex goal contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "contract_id",
    "objective",
    "non_goals",
    "allowed_roots",
    "budgets",
    "created_at",
    "created_by",
    "status",
    "runtime_profile",
    "goal_backend",
    "stop_conditions",
    "required_evidence",
    "promotion_guard"
  ],
  "properties": {
    "$schema": { "type": "string", "const": "ops/schemas/codex-goal-contract.schema.json" },
    "schema_version": { "type": "integer", "const": 1 },
    "contract_id": { "type": "string", "minLength": 1 },
    "objective": { "type": "string", "minLength": 1 },
    "non_goals": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "allowed_roots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "purpose"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "purpose": { "type": "string", "minLength": 1 }
        }
      }
    },
    "budgets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_wall_clock_seconds",
        "max_proposals",
        "max_consecutive_failures",
        "heartbeat_interval_seconds",
        "checkpoint_interval_seconds",
        "profile_ladder"
      ],
      "properties": {
        "max_wall_clock_seconds": { "type": "integer", "minimum": 1 },
        "max_proposals": { "type": "integer", "minimum": 1 },
        "max_consecutive_failures": { "type": "integer", "minimum": 1 },
        "heartbeat_interval_seconds": { "type": "integer", "minimum": 1 },
        "checkpoint_interval_seconds": { "type": "integer", "minimum": 1 },
        "profile_ladder": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "profile",
              "max_wall_clock_seconds",
              "max_proposals",
              "max_consecutive_failures",
              "required_before_next_profile"
            ],
            "properties": {
              "profile": {
                "type": "string",
                "enum": ["30m_trial", "6h_ramp", "2d_candidate", "5d_sustained"]
              },
              "max_wall_clock_seconds": { "type": "integer", "minimum": 1 },
              "max_proposals": { "type": "integer", "minimum": 1 },
              "max_consecutive_failures": { "type": "integer", "minimum": 1 },
              "required_before_next_profile": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "created_by": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["active", "paused", "completed", "failed", "stopped"]
    },
    "runtime_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "current_profile",
        "verified_profiles",
        "next_profile",
        "max_unattended_seconds"
      ],
      "properties": {
        "current_profile": {
          "type": "string",
          "enum": ["30m_trial", "6h_ramp", "2d_candidate", "5d_sustained"]
        },
        "verified_profiles": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["30m_trial", "6h_ramp", "2d_candidate", "5d_sustained"]
          },
          "uniqueItems": true
        },
        "next_profile": {
          "type": "string",
          "enum": ["30m_trial", "6h_ramp", "2d_candidate", "5d_sustained", "none"]
        },
        "max_unattended_seconds": { "type": "integer", "minimum": 1 }
      }
    },
    "goal_backend": {
      "type": "object",
      "additionalProperties": false,
      "required": ["backend_type", "process_persistent", "storage_path"],
      "properties": {
        "backend_type": {
          "type": "string",
          "enum": ["file", "run_local_file", "app_server"]
        },
        "process_persistent": { "type": "boolean", "const": true },
        "storage_path": { "type": "string", "minLength": 1 }
      }
    },
    "stop_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["condition_id", "description", "severity"],
        "properties": {
          "condition_id": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "severity": {
            "type": "string",
            "enum": ["stop", "pause", "require_review"]
          },
          "trigger": { "type": "string" }
        }
      }
    },
    "required_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "evidence_id",
          "path",
          "description",
          "freshness",
          "required_for_promotion"
        ],
        "properties": {
          "evidence_id": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "freshness": {
            "type": "string",
            "enum": ["current_run", "current_source_tree", "operator_reviewed"]
          },
          "required_for_promotion": { "type": "boolean" }
        }
      }
    },
    "promotion_guard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "can_promote_result",
        "promotion_blockers",
        "sealed_authority_clean",
        "profile_verified",
        "sustained_runtime_claimed",
        "no_sustained_claim_before_profile_verified"
      ],
      "properties": {
        "can_promote_result": { "type": "boolean" },
        "promotion_blockers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "sealed_authority_clean": { "type": "boolean" },
        "profile_verified": {
          "type": "string",
          "enum": ["unverified", "30m_trial", "6h_ramp", "2d_candidate", "5d_sustained"]
        },
        "sustained_runtime_claimed": { "type": "boolean" },
        "no_sustained_claim_before_profile_verified": { "type": "boolean", "const": true }
      },
      "allOf": [
        {
          "if": {
            "required": ["can_promote_result"],
            "properties": { "can_promote_result": { "const": true } }
          },
          "then": {
            "properties": {
              "promotion_blockers": { "maxItems": 0 },
              "sealed_authority_clean": { "const": true }
            }
          }
        },
        {
          "if": {
            "required": ["sustained_runtime_claimed"],
            "properties": { "sustained_runtime_claimed": { "const": true } }
          },
          "then": {
            "properties": {
              "can_promote_result": { "const": true },
              "sealed_authority_clean": { "const": true },
              "profile_verified": { "const": "5d_sustained" }
            }
          }
        }
      ]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
