{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LLM Wiki Remediation Backlog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "artifact_kind",
    "generated_at",
    "producer",
    "status",
    "source_readiness_report",
    "summary",
    "items"
  ],
  "properties": {
    "$schema": { "type": "string", "enum": ["ops/schemas/remediation-backlog.schema.json"] },
    "artifact_kind": { "type": "string", "enum": ["remediation_backlog"] },
    "schema_version": { "type": "integer", "minimum": 1 },
    "generated_at": { "type": "string", "minLength": 1 },
    "producer": { "type": "string", "minLength": 1 },
    "source_command": { "type": "string", "minLength": 1 },
    "source_revision": { "type": "string", "minLength": 1 },
    "source_tree_fingerprint": { "type": "string", "minLength": 1 },
    "input_fingerprints": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "artifact_status": {
      "type": "string",
      "enum": ["current", "archived", "stale", "unknown"]
    },
    "retention_policy": {
      "type": "string",
      "enum": ["ephemeral", "canonical_report", "archive"]
    },
    "encoding": { "type": "string", "enum": ["utf-8"] },
    "currentness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "checked_at"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["current", "stale", "unknown", "invalid"]
        },
        "checked_at": { "type": "string", "minLength": 1 }
      }
    },
    "status": { "type": "string", "enum": ["pass", "attention"] },
    "source_readiness_report": { "type": "string" },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["open_item_count", "repeated_blocker_count"],
      "properties": {
        "open_item_count": { "type": "integer", "minimum": 0 },
        "repeated_blocker_count": { "type": "integer", "minimum": 0 }
      }
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "source",
          "blocker",
          "blocker_kind",
          "status",
          "remediation_code",
          "recommended_next_step",
          "minimum_evidence"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "source": { "type": "string" },
          "blocker": { "type": "string" },
          "blocker_kind": { "type": "string" },
          "status": { "type": "string", "enum": ["open", "closed"] },
          "remediation_code": { "type": "string" },
          "recommended_next_step": { "type": "string" },
          "minimum_evidence": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
