{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LLM Wiki Script Output Surfaces",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "artifact_kind",
    "producer",
    "source_tree_scope",
    "version",
    "description",
    "classification_values",
    "surfaces"
  ],
  "properties": {
    "$schema": {
      "const": "ops/schemas/script-output-surfaces.schema.json"
    },
    "artifact_kind": {
      "const": "script_output_surfaces"
    },
    "producer": {
      "const": "ops.scripts.script_output_surfaces"
    },
    "source_tree_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "include_prefixes"],
      "properties": {
        "mode": {
          "const": "include_prefixes"
        },
        "include_prefixes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "classification_values": {
      "type": "array",
      "minItems": 5,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/classification"
      }
    },
    "surfaces": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/surface"
      }
    }
  },
  "$defs": {
    "classification": {
      "type": "string",
      "enum": [
        "repo_artifact",
        "user_export",
        "mixed",
        "no_output",
        "diagnostic_only"
      ]
    },
    "surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "classification",
        "output_options",
        "references_resolve_output_path",
        "references_resolve_repo_output_path",
        "direct_fallback_eligible",
        "reason"
      ],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^ops/scripts/([A-Za-z0-9_]+/)*[A-Za-z0-9_]+\\.py$"
        },
        "classification": {
          "$ref": "#/$defs/classification"
        },
        "output_options": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^--[A-Za-z0-9][A-Za-z0-9-]*$"
          }
        },
        "references_resolve_output_path": {
          "type": "boolean"
        },
        "references_resolve_repo_output_path": {
          "type": "boolean"
        },
        "direct_fallback_eligible": {
          "type": "boolean"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
