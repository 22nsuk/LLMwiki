{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LLM Wiki Planning Seed",
  "type": "object",
  "required": [
    "$schema",
    "run_id",
    "mode",
    "request",
    "state",
    "goals",
    "constraints",
    "success_criteria",
    "assumptions",
    "evidence",
    "signoff",
    "notes"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "enum": [
        "ops/schemas/seed.schema.json"
      ]
    },
    "run_id": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "enum": [
        "planning",
        "improvement"
      ]
    },
    "request": {
      "type": "object",
      "required": [
        "summary",
        "requester",
        "source_pages"
      ],
      "properties": {
        "summary": {
          "type": "string"
        },
        "requester": {
          "type": "string"
        },
        "source_pages": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "state": {
      "type": "object",
      "required": [
        "current",
        "allowed_next"
      ],
      "properties": {
        "current": {
          "type": "string",
          "enum": [
            "REQUEST_IN",
            "INTERVIEW",
            "SEED_DRAFT",
            "SEED_FROZEN",
            "PLAN_DRAFT",
            "VALIDATION",
            "WAITING_SIGNOFF",
            "READY",
            "BLOCKED"
          ]
        },
        "allowed_next": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "REQUEST_IN",
              "INTERVIEW",
              "SEED_DRAFT",
              "SEED_FROZEN",
              "PLAN_DRAFT",
              "VALIDATION",
              "WAITING_SIGNOFF",
              "READY",
              "BLOCKED"
            ]
          }
        }
      },
      "additionalProperties": false
    },
    "goals": {
      "type": "object",
      "required": [
        "primary",
        "non_goals"
      ],
      "properties": {
        "primary": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "non_goals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "constraints": {
      "type": "object",
      "required": [
        "hard",
        "soft"
      ],
      "properties": {
        "hard": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "soft": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "success_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "text",
          "trace"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "trace": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "assumptions": {
      "type": "object",
      "required": [
        "open",
        "frozen"
      ],
      "properties": {
        "open": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "frozen": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "object",
      "required": [
        "wiki_pages",
        "raw_sources"
      ],
      "properties": {
        "wiki_pages": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "raw_sources": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "public_sources": {
          "type": "array",
          "description": "Public-mirror-safe references (ops/, tests/, tools/, .github/) that do not depend on private corpus paths.",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "signoff": {
      "type": "object",
      "required": [
        "status",
        "by",
        "ts"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "approved",
            "rejected"
          ]
        },
        "by": {
          "type": "string"
        },
        "ts": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
