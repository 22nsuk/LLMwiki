{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Source Slug Curation Validation Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "manifest",
    "status",
    "error_count",
    "errors",
    "source_count"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "enum": [
        "ops/schemas/source-slug-curation-validation-report.schema.json"
      ]
    },
    "manifest": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    },
    "error_count": {
      "type": "integer",
      "minimum": 0
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "source_count": {
      "type": "integer",
      "minimum": 0
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    }
  },
  "$defs": {
    "metadata_property": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "value"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string"
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "properties"
      ],
      "properties": {
        "properties": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/metadata_property"
          }
        }
      }
    }
  }
}
