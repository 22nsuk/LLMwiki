{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Public Surface Snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "artifact_kind",
    "generated_at",
    "producer",
    "status",
    "summary",
    "include_files",
    "include_prefixes",
    "excluded_files",
    "excluded_prefixes",
    "missing_include_files",
    "missing_include_prefixes"
  ],
  "properties": {
    "$schema": { "type": "string", "const": "ops/schemas/public-surface-snapshot.schema.json" },
    "artifact_kind": { "type": "string", "const": "public_surface_snapshot" },
    "generated_at": { "type": "string", "minLength": 1 },
    "producer": { "type": "string", "const": "ops.scripts.public_surface_snapshot" },
    "status": { "type": "string", "enum": ["pass", "attention"] },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "include_file_count",
        "include_prefix_count",
        "missing_include_file_count",
        "missing_include_prefix_count",
        "excluded_file_count",
        "excluded_prefix_count"
      ],
      "properties": {
        "include_file_count": { "type": "integer", "minimum": 0 },
        "include_prefix_count": { "type": "integer", "minimum": 0 },
        "missing_include_file_count": { "type": "integer", "minimum": 0 },
        "missing_include_prefix_count": { "type": "integer", "minimum": 0 },
        "excluded_file_count": { "type": "integer", "minimum": 0 },
        "excluded_prefix_count": { "type": "integer", "minimum": 0 }
      }
    },
    "include_files": { "$ref": "#/$defs/path_statuses" },
    "include_prefixes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["prefix", "exists", "file_count"],
        "properties": {
          "prefix": { "type": "string", "minLength": 1 },
          "exists": { "type": "boolean" },
          "file_count": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "excluded_files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "present_in_local_tree"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "present_in_local_tree": { "type": "boolean" }
        }
      }
    },
    "excluded_prefixes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["prefix", "present"],
        "properties": {
          "prefix": { "type": "string", "minLength": 1 },
          "present": { "type": "boolean" }
        }
      }
    },
    "missing_include_files": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "missing_include_prefixes": { "type": "array", "items": { "type": "string", "minLength": 1 } }
  },
  "$defs": {
    "path_statuses": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "exists"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "exists": { "type": "boolean" }
        }
      }
    }
  }
}
