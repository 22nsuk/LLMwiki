{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LLM Wiki Planning Validation",
  "type": "object",
  "required": [
    "$schema",
    "run_id",
    "status",
    "summary",
    "checks",
    "open_questions",
    "signoff",
    "next_action"
  ],
  "$defs": {
    "metadata_property": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "value"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string"
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "properties"
      ],
      "properties": {
        "properties": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/metadata_property"
          }
        }
      }
    }
  },
  "properties": {
    "$schema": {
      "type": "string",
      "enum": [
        "ops/schemas/planning-validation.schema.json"
      ]
    },
    "run_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "PASS",
        "WARN",
        "FAIL"
      ]
    },
    "summary": {
      "type": "string"
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "status",
          "detail",
          "required_artifacts"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "PASS",
              "WARN",
              "FAIL"
            ]
          },
          "detail": {
            "type": "string"
          },
          "required_artifacts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "signoff": {
      "type": "object",
      "required": [
        "required",
        "status",
        "by",
        "ts"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "approved",
            "rejected",
            "not_required"
          ]
        },
        "by": {
          "type": "string"
        },
        "ts": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "next_action": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
