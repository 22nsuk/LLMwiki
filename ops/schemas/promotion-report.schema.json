{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LLM Wiki Promotion Report",
  "type": "object",
  "required": [
    "$schema",
    "run_id",
    "mode",
    "artifact_class",
    "decision",
    "summary",
    "primary_targets",
    "supporting_targets",
    "checks",
    "signoff",
    "log",
    "history",
    "next_action"
  ],
  "$defs": {
    "metadata_property": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "value"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string"
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "properties"
      ],
      "properties": {
        "properties": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/metadata_property"
          }
        }
      }
    },
    "promotion_decision": {
      "type": "string",
      "enum": [
        "PROMOTE",
        "HOLD",
        "DISCARD"
      ]
    },
    "promotion_outcome": {
      "type": "string",
      "enum": [
        "promoted",
        "hold",
        "discarded"
      ]
    },
    "decision_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_id",
        "subject_id",
        "subject_kind",
        "decision",
        "decision_stage",
        "is_terminal",
        "policy_version",
        "source_rule",
        "source_pass",
        "actor",
        "reason_code",
        "reason_detail",
        "evidence_refs",
        "decided_at",
        "effective_at",
        "supersedes",
        "reducer_key",
        "precedence_key",
        "dedupe_key",
        "finalizable",
        "finalize_blockers",
        "ledger_event_type",
        "ledger_partition_key"
      ],
      "properties": {
        "decision_id": {
          "type": "string",
          "minLength": 1
        },
        "subject_id": {
          "type": "string"
        },
        "subject_kind": {
          "type": "string"
        },
        "decision": {
          "$ref": "#/$defs/promotion_decision"
        },
        "decision_stage": {
          "type": "string",
          "enum": [
            "promotion_gate"
          ]
        },
        "is_terminal": {
          "type": "boolean"
        },
        "policy_version": {
          "type": "integer",
          "minimum": 0
        },
        "source_rule": {
          "type": "string"
        },
        "source_pass": {
          "type": "string"
        },
        "actor": {
          "type": "string"
        },
        "reason_code": {
          "type": "string"
        },
        "reason_detail": {
          "type": "string"
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "decided_at": {
          "type": "string"
        },
        "effective_at": {
          "type": "string"
        },
        "supersedes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reducer_key": {
          "type": "string",
          "enum": [
            "promotion_decision_registry_v1"
          ]
        },
        "precedence_key": {
          "type": "string"
        },
        "dedupe_key": {
          "type": "string"
        },
        "finalizable": {
          "type": "boolean"
        },
        "finalize_blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ledger_event_type": {
          "type": "string"
        },
        "ledger_partition_key": {
          "type": "string"
        }
      }
    },
    "decision_reduction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reducer_key",
        "selected_decision_id",
        "proposal_count",
        "proposals"
      ],
      "properties": {
        "reducer_key": {
          "type": "string",
          "enum": [
            "promotion_decision_registry_v1"
          ]
        },
        "selected_decision_id": {
          "type": "string"
        },
        "proposal_count": {
          "type": "integer",
          "minimum": 1
        },
        "proposals": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/decision_record"
          }
        }
      }
    }
  },
  "properties": {
    "$schema": {
      "type": "string",
      "enum": [
        "ops/schemas/promotion-report.schema.json"
      ]
    },
    "run_id": {
      "type": "string"
    },
    "proposal_id": {
      "type": "string"
    },
    "source_candidate_id": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "enum": [
        "report_only"
      ]
    },
    "artifact_class": {
      "type": "string",
      "enum": [
        "wiki_source",
        "wiki_concept",
        "wiki_synthesis",
        "wiki_query",
        "system_page",
        "system_mechanism"
      ]
    },
    "decision": {
      "$ref": "#/$defs/promotion_decision"
    },
    "outcome": {
      "$ref": "#/$defs/promotion_outcome"
    },
    "decision_record": {
      "$ref": "#/$defs/decision_record"
    },
    "decision_reduction": {
      "$ref": "#/$defs/decision_reduction"
    },
    "summary": {
      "type": "string"
    },
    "primary_targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "supporting_targets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "status",
          "detail"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "PASS",
              "WARN",
              "FAIL"
            ]
          },
          "detail": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "signoff": {
      "type": "object",
      "required": [
        "required",
        "status",
        "by",
        "ts"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "approved",
            "rejected",
            "not_required"
          ]
        },
        "by": {
          "type": "string"
        },
        "ts": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "log": {
      "type": "object",
      "required": [
        "required",
        "page",
        "summary",
        "status",
        "entry_ref"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "page": {
          "type": "string",
          "enum": [
            "system/system-log.md"
          ]
        },
        "summary": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "recorded",
            "not_required"
          ]
        },
        "entry_ref": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "history": {
      "type": "object",
      "required": [
        "status",
        "reason",
        "by",
        "ts"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "active",
            "archived",
            "quarantined"
          ]
        },
        "reason": {
          "type": "string"
        },
        "by": {
          "type": "string"
        },
        "ts": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "next_action": {
      "type": "string"
    },
    "inputs": {
      "type": "object",
      "properties": {
        "current_lint": {
          "type": "object",
          "required": [
            "status",
            "error_count",
            "warning_count",
            "review_candidate_count"
          ],
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "pass",
                "warn",
                "fail"
              ]
            },
            "error_count": {
              "type": "integer"
            },
            "warning_count": {
              "type": "integer"
            },
            "review_candidate_count": {
              "type": "integer"
            }
          },
          "additionalProperties": false
        },
        "current_eval": {
          "type": "object",
          "required": [
            "status",
            "total_score",
            "max_score"
          ],
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "pass",
                "fail"
              ]
            },
            "total_score": {
              "type": "integer"
            },
            "max_score": {
              "type": "integer"
            }
          },
          "additionalProperties": false
        },
        "current_stage2": {
          "type": "object",
          "required": [
            "status",
            "total_score",
            "max_score"
          ],
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "pass",
                "fail"
              ]
            },
            "total_score": {
              "type": "integer"
            },
            "max_score": {
              "type": "integer"
            }
          },
          "additionalProperties": false
        },
        "baseline_eval_report": {
          "type": "string"
        },
        "candidate_eval_report": {
          "type": "string"
        },
        "baseline_mechanism_contract_eval_report": {
          "type": "string"
        },
        "candidate_mechanism_contract_eval_report": {
          "type": "string"
        },
        "baseline_lint_report": {
          "type": "string"
        },
        "candidate_lint_report": {
          "type": "string"
        },
        "baseline_mechanism_report": {
          "type": "string"
        },
        "candidate_mechanism_report": {
          "type": "string"
        },
        "changed_files_manifest": {
          "type": "string"
        },
        "behavior_delta": {
          "type": "string"
        },
        "run_ledger": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "diagnostics": {
      "type": "object",
      "required": [
        "global_eval_delta",
        "global_eval_failure_summary",
        "global_eval_lane_summary",
        "mechanism_contract_eval",
        "mechanism_eval_applicability"
      ],
      "properties": {
        "global_eval_delta": {
          "type": "object",
          "required": [
            "baseline_status",
            "candidate_status",
            "baseline_total_score",
            "candidate_total_score",
            "total_score_delta",
            "baseline_max_score",
            "candidate_max_score",
            "max_score_delta",
            "score_regressed",
            "status_regressed"
          ],
          "properties": {
            "baseline_status": {
              "type": "string",
              "enum": [
                "pass",
                "fail"
              ]
            },
            "candidate_status": {
              "type": "string",
              "enum": [
                "pass",
                "fail"
              ]
            },
            "baseline_total_score": {
              "type": "integer"
            },
            "candidate_total_score": {
              "type": "integer"
            },
            "total_score_delta": {
              "type": "integer"
            },
            "baseline_max_score": {
              "type": "integer"
            },
            "candidate_max_score": {
              "type": "integer"
            },
            "max_score_delta": {
              "type": "integer"
            },
            "score_regressed": {
              "type": "boolean"
            },
            "status_regressed": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        "global_eval_failure_summary": {
          "type": "object",
          "required": [
            "baseline_failed_check_count",
            "candidate_failed_check_count",
            "failed_check_delta",
            "baseline_failed_page_count",
            "candidate_failed_page_count",
            "failed_page_delta",
            "baseline_failures_by_eval",
            "candidate_failures_by_eval",
            "changed_failures_by_eval",
            "candidate_new_failure_count",
            "candidate_resolved_failure_count"
          ],
          "properties": {
            "baseline_failed_check_count": {
              "type": "integer"
            },
            "candidate_failed_check_count": {
              "type": "integer"
            },
            "failed_check_delta": {
              "type": "integer"
            },
            "baseline_failed_page_count": {
              "type": "integer"
            },
            "candidate_failed_page_count": {
              "type": "integer"
            },
            "failed_page_delta": {
              "type": "integer"
            },
            "baseline_failures_by_eval": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "eval",
                  "count"
                ],
                "properties": {
                  "eval": {
                    "type": "string"
                  },
                  "count": {
                    "type": "integer"
                  }
                },
                "additionalProperties": false
              }
            },
            "candidate_failures_by_eval": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "eval",
                  "count"
                ],
                "properties": {
                  "eval": {
                    "type": "string"
                  },
                  "count": {
                    "type": "integer"
                  }
                },
                "additionalProperties": false
              }
            },
            "changed_failures_by_eval": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "eval",
                  "baseline_count",
                  "candidate_count",
                  "delta"
                ],
                "properties": {
                  "eval": {
                    "type": "string"
                  },
                  "baseline_count": {
                    "type": "integer"
                  },
                  "candidate_count": {
                    "type": "integer"
                  },
                  "delta": {
                    "type": "integer"
                  }
                },
                "additionalProperties": false
              }
            },
            "candidate_new_failure_count": {
              "type": "integer"
            },
            "candidate_resolved_failure_count": {
              "type": "integer"
            }
          },
          "additionalProperties": false
        },
        "global_eval_lane_summary": {
          "type": "object",
          "required": [
            "global_eval_role",
            "content_corpus_eval_ids",
            "candidate_content_corpus_backlog_count",
            "content_corpus_backlog_delta",
            "content_corpus_backlog_like",
            "content_corpus_backlog_evals_present",
            "mechanism_local_failure_count",
            "mechanism_local_new_failure_count",
            "recommended_lane"
          ],
          "properties": {
            "global_eval_role": {
              "type": "string",
              "enum": [
                "non_regression_guard"
              ]
            },
            "content_corpus_eval_ids": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "candidate_content_corpus_backlog_count": {
              "type": "integer"
            },
            "content_corpus_backlog_delta": {
              "type": "integer"
            },
            "content_corpus_backlog_like": {
              "type": "boolean"
            },
            "content_corpus_backlog_evals_present": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "mechanism_local_failure_count": {
              "type": "integer"
            },
            "mechanism_local_new_failure_count": {
              "type": "integer"
            },
            "recommended_lane": {
              "type": "string",
              "enum": [
                "content_corpus",
                "mechanism_or_global_regression",
                "none"
              ]
            }
          },
          "additionalProperties": false
        },
        "mechanism_contract_eval": {
          "type": "object",
          "required": [
            "source",
            "score_source",
            "baseline_report",
            "candidate_report",
            "baseline_status",
            "candidate_status",
            "baseline_total_score",
            "candidate_total_score",
            "total_score_delta",
            "score_improves",
            "score_equal"
          ],
          "properties": {
            "source": {
              "type": "string",
              "enum": [
                "provided",
                "missing"
              ]
            },
            "score_source": {
              "type": "string",
              "enum": [
                "mechanism_contract_eval",
                "mechanism_contract_eval_missing"
              ]
            },
            "baseline_report": {
              "type": "string"
            },
            "candidate_report": {
              "type": "string"
            },
            "baseline_status": {
              "type": "string"
            },
            "candidate_status": {
              "type": "string"
            },
            "baseline_total_score": {
              "type": "integer"
            },
            "candidate_total_score": {
              "type": "integer"
            },
            "total_score_delta": {
              "type": "integer"
            },
            "score_improves": {
              "type": "boolean"
            },
            "score_equal": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        "mechanism_eval_applicability": {
          "type": "object",
          "required": [
            "artifact_class",
            "classification",
            "candidate_failure_mode",
            "candidate_regression",
            "corpus_backlog_like",
            "reason"
          ],
          "properties": {
            "artifact_class": {
              "type": "string"
            },
            "classification": {
              "type": "string",
              "enum": [
                "mechanism_contract_eval",
                "global_health_guard_only",
                "direct_eval_signal"
              ]
            },
            "candidate_failure_mode": {
              "type": "string",
              "enum": [
                "candidate_clean",
                "candidate_regression",
                "baseline_backlog_non_regression"
              ]
            },
            "candidate_regression": {
              "type": "boolean"
            },
            "corpus_backlog_like": {
              "type": "boolean"
            },
            "reason": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    }
  },
  "additionalProperties": false
}
