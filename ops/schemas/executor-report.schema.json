{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LLM Wiki Executor Report",
  "type": "object",
  "required": [
    "$schema",
    "run_id",
    "role",
    "input_digest",
    "generated_at",
    "executor",
    "status",
    "command",
    "artifacts",
    "result",
    "diagnostics"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "enum": [
        "ops/schemas/executor-report.schema.json"
      ]
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "type": "string",
      "minLength": 1
    },
    "input_digest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "executor": {
      "type": "object",
      "required": [
        "name",
        "sandbox_mode",
        "model",
        "reasoning_effort"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "sandbox_mode": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "reasoning_effort": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    },
    "command": {
      "type": "object",
      "required": [
        "argv"
      ],
      "properties": {
        "argv": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "artifacts": {
      "type": "object",
      "required": [
        "prompt",
        "output_last_message",
        "stdout",
        "stderr",
        "command_log_summary",
        "timeout_failure"
      ],
      "properties": {
        "prompt": {
          "type": "string"
        },
        "output_last_message": {
          "type": "string"
        },
        "stdout": {
          "type": "string"
        },
        "stderr": {
          "type": "string"
        },
        "command_log_summary": {
          "type": "string"
        },
        "timeout_failure": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "result": {
      "type": "object",
      "required": [
        "returncode",
        "timed_out",
        "timeout_seconds",
        "termination_reason",
        "launch_succeeded",
        "signal_sent",
        "final_state_observed",
        "stdout_received",
        "stderr_received",
        "observability"
      ],
      "properties": {
        "returncode": {
          "type": "integer"
        },
        "timed_out": {
          "type": "boolean"
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "termination_reason": {
          "type": "string",
          "enum": [
            "completed",
            "timeout"
          ]
        },
        "launch_succeeded": {
          "type": "boolean"
        },
        "signal_sent": {
          "type": "string"
        },
        "final_state_observed": {
          "type": "string"
        },
        "stdout_received": {
          "type": "boolean"
        },
        "stderr_received": {
          "type": "boolean"
        },
        "observability": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "heartbeat_count",
            "heartbeat_interval_seconds",
            "quiet_seconds",
            "last_stdout_at",
            "last_stderr_at",
            "last_artifact_touch_at",
            "observation_mode"
          ],
          "properties": {
            "heartbeat_count": {
              "type": "integer",
              "minimum": 0
            },
            "heartbeat_interval_seconds": {
              "type": "integer",
              "minimum": 0
            },
            "quiet_seconds": {
              "type": "integer",
              "minimum": 0
            },
            "last_stdout_at": {
              "type": "string"
            },
            "last_stderr_at": {
              "type": "string"
            },
            "last_artifact_touch_at": {
              "type": "string"
            },
            "observation_mode": {
              "type": "string",
              "enum": [
                "communicate",
                "process_heartbeat"
              ]
            }
          }
        }
      },
      "additionalProperties": false
    },
    "diagnostics": {
      "type": "object",
      "required": [
        "routing_report",
        "scope_freeze",
        "dependency_preflight",
        "notes"
      ],
      "properties": {
        "routing_report": {
          "type": "string"
        },
        "scope_freeze": {
          "type": "string"
        },
        "dependency_preflight": {
          "type": "object",
          "required": [
            "role_requires_project_check",
            "status",
            "command",
            "python",
            "required_modules",
            "returncode"
          ],
          "properties": {
            "role_requires_project_check": {
              "type": "boolean"
            },
            "status": {
              "type": "string",
              "enum": [
                "not_required",
                "not_checked",
                "pass",
                "fail"
              ]
            },
            "command": {
              "type": "object",
              "required": [
                "argv",
                "project_check_lane"
              ],
              "properties": {
                "argv": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "project_check_lane": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            },
            "python": {
              "type": "object",
              "required": [
                "path",
                "executable",
                "version",
                "exists"
              ],
              "properties": {
                "path": {
                  "type": "string"
                },
                "executable": {
                  "type": "string"
                },
                "version": {
                  "type": "string"
                },
                "exists": {
                  "type": "boolean"
                }
              },
              "additionalProperties": false
            },
            "required_modules": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "import_name",
                  "package",
                  "status",
                  "version",
                  "detail"
                ],
                "properties": {
                  "import_name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "package": {
                    "type": "string",
                    "minLength": 1
                  },
                  "status": {
                    "type": "string",
                    "enum": [
                      "not_checked",
                      "available",
                      "missing",
                      "unknown"
                    ]
                  },
                  "version": {
                    "type": "string"
                  },
                  "detail": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              }
            },
            "returncode": {
              "type": "integer"
            }
          },
          "additionalProperties": false
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
