{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LLM Wiki Mechanism Assessment Report",
  "type": "object",
  "required": [
    "$schema",
    "vault",
    "generated_at",
    "policy",
    "primary_targets",
    "supporting_targets",
    "test_files",
    "structural_metrics",
    "complexity_profile"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "enum": [
        "ops/schemas/mechanism-assessment-report.schema.json"
      ]
    },
    "vault": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "metadata": {
      "type": "object"
    },
    "policy": {
      "type": "object",
      "required": [
        "path",
        "version"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "version": {
          "type": "integer"
        }
      },
      "additionalProperties": false
    },
    "primary_targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "supporting_targets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "test_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "structural_metrics": {
      "type": "object",
      "required": [
        "nonempty_line_count_total",
        "python_function_count",
        "python_branch_node_count",
        "markdown_heading_count",
        "test_file_count",
        "test_case_count"
      ],
      "properties": {
        "nonempty_line_count_total": {
          "type": "integer"
        },
        "python_function_count": {
          "type": "integer"
        },
        "python_branch_node_count": {
          "type": "integer"
        },
        "markdown_heading_count": {
          "type": "integer"
        },
        "test_file_count": {
          "type": "integer"
        },
        "test_case_count": {
          "type": "integer"
        }
      },
      "additionalProperties": false
    },
    "total_structural_metrics": {
      "type": "object",
      "required": [
        "nonempty_line_count_total",
        "python_function_count",
        "python_branch_node_count",
        "markdown_heading_count",
        "test_file_count",
        "test_case_count"
      ],
      "properties": {
        "nonempty_line_count_total": {
          "type": "integer"
        },
        "python_function_count": {
          "type": "integer"
        },
        "python_branch_node_count": {
          "type": "integer"
        },
        "markdown_heading_count": {
          "type": "integer"
        },
        "test_file_count": {
          "type": "integer"
        },
        "test_case_count": {
          "type": "integer"
        }
      },
      "additionalProperties": false
    },
    "diagnostics": {
      "type": "object",
      "required": [
        "unreadable_targets",
        "python_parse_failures"
      ],
      "properties": {
        "unreadable_targets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "path",
              "reason"
            ],
            "properties": {
              "path": {
                "type": "string"
              },
              "reason": {
                "type": "string"
              },
              "detail": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "python_parse_failures": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "path",
              "reason"
            ],
            "properties": {
              "path": {
                "type": "string"
              },
              "reason": {
                "type": "string"
              },
              "detail": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "complexity_profile": {
      "type": "object",
      "required": [
        "dimensions",
        "complexity_score",
        "risk_flags",
        "primary_targets",
        "supporting_targets",
        "test_files",
        "risk_flag_evidence",
        "target_profiles",
        "dimension_evidence"
      ],
      "properties": {
        "dimensions": {
          "type": "object",
          "required": [
            "change_surface",
            "dependency_impact",
            "verification_cost",
            "artifact_heterogeneity",
            "environment_risk"
          ],
          "properties": {
            "change_surface": {
              "type": "integer"
            },
            "dependency_impact": {
              "type": "integer"
            },
            "verification_cost": {
              "type": "integer"
            },
            "artifact_heterogeneity": {
              "type": "integer"
            },
            "environment_risk": {
              "type": "integer"
            }
          },
          "additionalProperties": false
        },
        "complexity_score": {
          "type": "integer"
        },
        "risk_flags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "primary_targets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "supporting_targets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "test_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "risk_flag_evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "flag",
              "path",
              "reason"
            ],
            "properties": {
              "flag": {
                "type": "string"
              },
              "path": {
                "type": "string"
              },
              "reason": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "target_profiles": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "path",
              "kind",
              "nonempty_line_count",
              "python_function_count",
              "python_branch_node_count",
              "markdown_heading_count",
              "python_semantic_complexity_points",
              "whole_file_volume",
              "coarse_target"
            ],
            "properties": {
              "path": {
                "type": "string"
              },
              "kind": {
                "type": "string",
                "enum": [
                  "python",
                  "markdown",
                  "yaml",
                  "json",
                  "other"
                ]
              },
              "nonempty_line_count": {
                "type": "integer"
              },
              "python_function_count": {
                "type": "integer"
              },
              "python_branch_node_count": {
                "type": "integer"
              },
              "markdown_heading_count": {
                "type": "integer"
              },
              "python_semantic_complexity_points": {
                "type": "integer"
              },
              "whole_file_volume": {
                "type": "integer"
              },
              "coarse_target": {
                "type": "boolean"
              }
            },
            "additionalProperties": false
          }
        },
        "dimension_evidence": {
          "type": "object",
          "required": [
            "change_surface",
            "verification_cost"
          ],
          "properties": {
            "change_surface": {
              "type": "object",
              "required": [
                "target_count",
                "target_count_score",
                "whole_file_volume",
                "whole_file_volume_score",
                "per_target_capped_volume",
                "per_target_capped_volume_score",
                "semantic_volume",
                "semantic_volume_score",
                "large_file_target_count",
                "coarse_target_bias_mitigated",
                "selected_score"
              ],
              "properties": {
                "target_count": {
                  "type": "integer"
                },
                "target_count_score": {
                  "type": "integer"
                },
                "whole_file_volume": {
                  "type": "integer"
                },
                "whole_file_volume_score": {
                  "type": "integer"
                },
                "per_target_capped_volume": {
                  "type": "integer"
                },
                "per_target_capped_volume_score": {
                  "type": "integer"
                },
                "semantic_volume": {
                  "type": "integer"
                },
                "semantic_volume_score": {
                  "type": "integer"
                },
                "large_file_target_count": {
                  "type": "integer"
                },
                "coarse_target_bias_mitigated": {
                  "type": "boolean"
                },
                "selected_score": {
                  "type": "integer"
                }
              },
              "additionalProperties": false
            },
            "verification_cost": {
              "type": "object",
              "required": [
                "target_count",
                "test_file_count",
                "test_case_count",
                "verification_scope",
                "reasons",
                "selected_score"
              ],
              "properties": {
                "target_count": {
                  "type": "integer"
                },
                "test_file_count": {
                  "type": "integer"
                },
                "test_case_count": {
                  "type": "integer"
                },
                "verification_scope": {
                  "type": "string"
                },
                "reasons": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "selected_score": {
                  "type": "integer"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
