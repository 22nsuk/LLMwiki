{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llmwiki.local/schemas/goal-runtime-certificate.schema.json",
  "title": "Goal runtime certificate report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "artifact_kind",
    "generated_at",
    "producer",
    "source_command",
    "source_revision",
    "source_tree_fingerprint",
    "input_fingerprints",
    "schema_version",
    "artifact_status",
    "retention_policy",
    "encoding",
    "currentness",
    "vault",
    "goal",
    "certificate",
    "run",
    "run_artifacts",
    "session_evidence",
    "command_observability",
    "evidence_paths",
    "diagnosis",
    "contract_update",
    "blockers",
    "status"
  ],
  "properties": {
    "$schema": { "type": "string", "const": "ops/schemas/goal-runtime-certificate.schema.json" },
    "artifact_kind": { "type": "string", "const": "goal_runtime_certificate" },
    "generated_at": { "type": "string", "minLength": 1 },
    "producer": { "type": "string", "const": "ops.scripts.goal_runtime_certificate_report" },
    "source_command": { "type": "string", "minLength": 1 },
    "source_revision": { "type": "string" },
    "source_tree_fingerprint": { "type": "string", "minLength": 1 },
    "input_fingerprints": { "type": "object" },
    "schema_version": { "type": "integer", "const": 1 },
    "artifact_status": { "type": "string" },
    "retention_policy": { "type": "string" },
    "encoding": { "type": "string", "const": "utf-8" },
    "currentness": { "type": "object" },
    "vault": { "type": "string" },
    "goal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract_path",
        "contract_id",
        "contract_sha256_before",
        "contract_sha256_after"
      ],
      "properties": {
        "contract_path": { "type": "string", "minLength": 1 },
        "contract_id": { "type": "string", "minLength": 1 },
        "contract_sha256_before": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "contract_sha256_after": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "certificate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_runtime_mode",
        "verification_status",
        "max_runtime_seconds",
        "observed_elapsed_seconds",
        "already_verified",
        "eligible"
      ],
      "properties": {
        "target_runtime_mode": {
          "type": "string",
          "enum": ["self_improvement_loop"]
        },
        "verification_status": {
          "type": "string",
          "enum": ["blocked", "eligible", "already_verified"]
        },
        "max_runtime_seconds": { "type": "integer", "minimum": 1 },
        "observed_elapsed_seconds": { "type": "integer", "minimum": 0 },
        "already_verified": { "type": "boolean" },
        "eligible": { "type": "boolean" }
      }
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status_report_path",
        "run_id",
        "run_status",
        "run_runtime_mode",
        "started_at",
        "completed_at"
      ],
      "properties": {
        "status_report_path": { "type": "string", "minLength": 1 },
        "run_id": { "type": "string" },
        "run_status": { "type": "string" },
        "run_runtime_mode": { "type": "string" },
        "started_at": { "type": "string" },
        "completed_at": { "type": "string" }
      }
    },
    "run_artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "checks", "audit_event_count", "runner_command_audit_current"],
      "properties": {
        "status": { "type": "string", "enum": ["clean", "incomplete", "missing"] },
        "checks": {
          "type": "array",
          "items": { "$ref": "#/$defs/artifact_check" }
        },
        "audit_event_count": { "type": "integer", "minimum": 0 },
        "runner_command_audit_current": { "type": "boolean" }
      }
    },
    "session_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "path",
        "session_status",
        "stop_reason",
        "iteration_count",
        "successful_iteration_count",
        "has_success_then_followup",
        "accepted_stop_reasons",
        "minimum_iteration_count",
        "minimum_successful_iteration_count",
        "requires_success_then_followup",
        "requires_meaningful_maintenance",
        "maintenance_status",
        "maintenance_cycle_count",
        "meaningful_maintenance_cycle_count",
        "expected_min_maintenance_cycle_count",
        "maintenance_last_cycle_elapsed_seconds"
      ],
      "properties": {
        "status": { "type": "string", "enum": ["clean", "incomplete", "missing"] },
        "path": { "type": "string" },
        "session_status": { "type": "string" },
        "stop_reason": { "type": "string" },
        "iteration_count": { "type": "integer", "minimum": 0 },
        "successful_iteration_count": { "type": "integer", "minimum": 0 },
        "has_success_then_followup": { "type": "boolean" },
        "accepted_stop_reasons": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "minimum_iteration_count": { "type": "integer", "minimum": 0 },
        "minimum_successful_iteration_count": { "type": "integer", "minimum": 0 },
        "requires_success_then_followup": { "type": "boolean" },
        "requires_meaningful_maintenance": { "type": "boolean" },
        "maintenance_status": {
          "type": "string",
          "enum": ["clean", "incomplete", "missing"]
        },
        "maintenance_cycle_count": { "type": "integer", "minimum": 0 },
        "meaningful_maintenance_cycle_count": { "type": "integer", "minimum": 0 },
        "expected_min_maintenance_cycle_count": { "type": "integer", "minimum": 0 },
        "maintenance_last_cycle_elapsed_seconds": { "type": "integer", "minimum": 0 }
      }
    },
    "command_observability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "heartbeat_count",
        "expected_min_heartbeat_count",
        "timeout_seconds",
        "last_command_returncode",
        "last_command_timed_out",
        "last_command_termination_reason",
        "last_command_heartbeat_at",
        "runner_audit_current",
        "status"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["", "communicate", "process_heartbeat", "process_poll"]
        },
        "heartbeat_count": { "type": "integer", "minimum": 0 },
        "expected_min_heartbeat_count": { "type": "integer", "minimum": 0 },
        "timeout_seconds": { "type": "integer", "minimum": 0 },
        "last_command_returncode": { "type": "integer" },
        "last_command_timed_out": { "type": "boolean" },
        "last_command_termination_reason": { "type": "string" },
        "last_command_heartbeat_at": { "type": "string" },
        "runner_audit_current": { "type": "boolean" },
        "status": { "type": "string", "enum": ["clean", "incomplete"] }
      }
    },
    "evidence_paths": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidence_path" }
    },
    "diagnosis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_type",
        "certificate_claim_status",
        "report_status_meaning",
        "current_scope",
        "mechanism_promote_evidence_policy",
        "primary_blocker_categories",
        "certifiable"
      ],
      "properties": {
        "claim_type": {
          "type": "string",
          "const": "sustained_self_improvement_loop_certificate"
        },
        "certificate_claim_status": {
          "type": "string",
          "enum": ["eligible", "already_verified", "not_yet_certifiable"]
        },
        "report_status_meaning": { "type": "string", "minLength": 1 },
        "current_scope": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status_report_path",
            "run_id",
            "run_status",
            "runtime_mode",
            "session_evidence_path"
          ],
          "properties": {
            "status_report_path": { "type": "string", "minLength": 1 },
            "run_id": { "type": "string" },
            "run_status": { "type": "string" },
            "runtime_mode": { "type": "string" },
            "session_evidence_path": { "type": "string" }
          }
        },
        "mechanism_promote_evidence_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "mechanism_promote_sufficient_for_certificate",
            "role"
          ],
          "properties": {
            "mechanism_promote_sufficient_for_certificate": { "type": "boolean", "const": false },
            "role": { "type": "string", "minLength": 1 }
          }
        },
        "primary_blocker_categories": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "runtime_run",
              "session_evidence",
              "command_observability",
              "required_evidence",
              "promotion_guard",
              "sealed_authority",
              "runtime_budget",
              "runtime_mode",
              "other"
            ]
          }
        },
        "certifiable": { "type": "boolean" }
      }
    },
    "contract_update": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "apply_requested",
        "apply_allowed",
        "applied",
        "certificate_status_before",
        "certificate_status_after",
        "runtime_certificate_verified_before",
        "runtime_certificate_verified_after"
      ],
      "properties": {
        "apply_requested": { "type": "boolean" },
        "apply_allowed": { "type": "boolean" },
        "applied": { "type": "boolean" },
        "certificate_status_before": { "$ref": "#/$defs/certificate_status" },
        "certificate_status_after": { "$ref": "#/$defs/certificate_status" },
        "runtime_certificate_verified_before": { "type": "boolean" },
        "runtime_certificate_verified_after": { "type": "boolean" }
      }
    },
    "blockers": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "status": { "type": "string", "enum": ["pass", "attention"] }
  },
  "$defs": {
    "certificate_status": {
      "type": "string",
      "enum": ["unverified", "verified"]
    },
    "artifact_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact", "path", "status"],
      "properties": {
        "artifact": { "type": "string", "minLength": 1 },
        "path": { "type": "string" },
        "status": { "type": "string", "enum": ["present", "missing", "pass", "fail"] }
      }
    },
    "evidence_path": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "status"],
      "properties": {
        "evidence_id": { "type": "string" },
        "path": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["present", "missing"] },
        "report_status": { "type": "string" },
        "preflight_status": { "type": "string" },
        "distribution_binding_status": { "type": "string" },
        "authority_preflight_status": { "type": "string" }
      }
    }
  }
}
