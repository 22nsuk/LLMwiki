{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LLM Wiki Release Workflow Order Guard Spec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "version",
    "target_recipe_order",
    "role_overrides",
    "role_override_sequence_coverage",
    "protected_recipes",
    "expected_subsequences",
    "terminal_checks",
    "first_role_checks",
    "repetition_budgets",
    "forbidden_target_checks",
    "source_paths",
    "file_inputs"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "ops/schemas/release-workflow-order-guard-spec.schema.json"
    },
    "version": { "type": "integer", "minimum": 1 },
    "target_recipe_order": {
      "$ref": "#/$defs/non_empty_make_target_list"
    },
    "role_overrides": {
      "type": "array",
      "items": { "$ref": "#/$defs/role_override" }
    },
    "role_override_sequence_coverage": {
      "$ref": "#/$defs/role_override_sequence_coverage"
    },
    "protected_recipes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/protected_recipe" }
    },
    "expected_subsequences": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/expected_subsequence" }
    },
    "terminal_checks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/terminal_check" }
    },
    "first_role_checks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/first_role_check" }
    },
    "repetition_budgets": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/repetition_budget" }
    },
    "forbidden_target_checks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/forbidden_target_check" }
    },
    "source_paths": {
      "type": "object",
      "additionalProperties": false,
      "required": ["static", "include_makefile_sources"],
      "properties": {
        "static": { "$ref": "#/$defs/string_list" },
        "include_makefile_sources": { "type": "boolean" }
      }
    },
    "file_inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["static", "include_makefile_sources"],
      "properties": {
        "static": {
          "type": "object",
          "additionalProperties": { "type": "string", "minLength": 1 }
        },
        "include_makefile_sources": { "type": "boolean" }
      }
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "check_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "make_target": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_.-]*$"
    },
    "make_target_list": {
      "type": "array",
      "items": { "$ref": "#/$defs/make_target" },
      "uniqueItems": true
    },
    "non_empty_make_target_list": {
      "allOf": [
        { "$ref": "#/$defs/make_target_list" },
        { "minItems": 1 }
      ]
    },
    "string_list": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" },
      "uniqueItems": true
    },
    "ordered_non_empty_make_target_list": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/make_target" }
    },
    "role_override": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "required_assignments", "role"],
      "properties": {
        "target": { "$ref": "#/$defs/make_target" },
        "required_assignments": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": {
            "type": "string",
            "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
          },
          "additionalProperties": { "$ref": "#/$defs/non_empty_string" }
        },
        "role": { "$ref": "#/$defs/make_target" }
      }
    },
    "role_override_sequence_coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowlisted_roles", "details"],
      "properties": {
        "allowlisted_roles": { "$ref": "#/$defs/make_target_list" },
        "details": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "protected_recipe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "target", "expected_lines", "details"],
      "properties": {
        "id": { "$ref": "#/$defs/check_id" },
        "target": { "$ref": "#/$defs/make_target" },
        "expected_lines": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/protected_recipe_line" }
        },
        "details": { "type": "string" }
      }
    },
    "protected_recipe_line": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "target", "raw_line"],
      "properties": {
        "role": { "$ref": "#/$defs/make_target" },
        "target": { "$ref": "#/$defs/make_target" },
        "raw_line": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "expected_subsequence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "target", "roles", "details"],
      "properties": {
        "id": { "$ref": "#/$defs/check_id" },
        "target": { "$ref": "#/$defs/make_target" },
        "roles": { "$ref": "#/$defs/ordered_non_empty_make_target_list" },
        "exact": { "type": "boolean" },
        "details": { "type": "string" }
      }
    },
    "terminal_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "target", "role", "reason"],
      "properties": {
        "id": { "$ref": "#/$defs/check_id" },
        "target": { "$ref": "#/$defs/make_target" },
        "role": { "$ref": "#/$defs/make_target" },
        "reason": { "$ref": "#/$defs/non_empty_string" },
        "details": { "type": "string" }
      }
    },
    "first_role_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "target", "role", "reason"],
      "properties": {
        "id": { "$ref": "#/$defs/check_id" },
        "target": { "$ref": "#/$defs/make_target" },
        "role": { "$ref": "#/$defs/make_target" },
        "reason": { "$ref": "#/$defs/non_empty_string" },
        "details": { "type": "string" }
      }
    },
    "repetition_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "target", "allowed_repeated_targets", "violation_reason", "details"],
      "properties": {
        "id": { "$ref": "#/$defs/check_id" },
        "target": { "$ref": "#/$defs/make_target" },
        "allowed_repeated_targets": { "$ref": "#/$defs/make_target_list" },
        "violation_reason": { "$ref": "#/$defs/non_empty_string" },
        "expected_order_label": { "$ref": "#/$defs/non_empty_string" },
        "details": { "type": "string" }
      }
    },
    "forbidden_target_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "target", "forbidden_targets", "violation_reason"],
      "properties": {
        "id": { "$ref": "#/$defs/check_id" },
        "target": { "$ref": "#/$defs/make_target" },
        "forbidden_targets": { "$ref": "#/$defs/non_empty_make_target_list" },
        "violation_reason": { "$ref": "#/$defs/non_empty_string" },
        "details": { "type": "string" }
      }
    }
  }
}
