{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CLI Surface Inventory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "artifact_kind",
    "generated_at",
    "producer",
    "status",
    "summary",
    "modules",
    "unclassified_modules",
    "unresolved_modules"
  ],
  "properties": {
    "$schema": { "type": "string", "const": "ops/schemas/cli-surface-inventory.schema.json" },
    "artifact_kind": { "type": "string", "const": "cli_surface_inventory" },
    "generated_at": { "type": "string", "minLength": 1 },
    "producer": { "type": "string", "const": "ops.scripts.cli_surface_inventory" },
    "status": { "type": "string", "enum": ["pass", "fail"] },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "module_count",
        "pyproject_script_count",
        "makefile_module_invocation_count",
        "direct_fallback_module_count",
        "lifecycle_policy_module_count",
        "public_cli_module_count",
        "transitional_installed_module_count",
        "installed_non_public_module_count",
        "unclassified_module_count",
        "unresolved_module_count"
      ],
      "properties": {
        "module_count": { "type": "integer", "minimum": 0 },
        "pyproject_script_count": { "type": "integer", "minimum": 0 },
        "makefile_module_invocation_count": { "type": "integer", "minimum": 0 },
        "direct_fallback_module_count": { "type": "integer", "minimum": 0 },
        "lifecycle_policy_module_count": { "type": "integer", "minimum": 0 },
        "public_cli_module_count": { "type": "integer", "minimum": 0 },
        "transitional_installed_module_count": { "type": "integer", "minimum": 0 },
        "installed_non_public_module_count": { "type": "integer", "minimum": 0 },
        "unclassified_module_count": { "type": "integer", "minimum": 0 },
        "unresolved_module_count": { "type": "integer", "minimum": 0 }
      }
    },
    "modules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "module",
          "path",
          "aliases",
          "sources",
          "lifecycle",
          "install_state",
          "console_scripts",
          "direct_fallback",
          "make_targets",
          "replacement",
          "removal_ready"
        ],
        "properties": {
          "module": { "type": "string", "minLength": 1 },
          "path": { "type": "string" },
          "aliases": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "pyproject_scripts",
                "makefile_module_invocations",
                "direct_fallback_modules"
              ]
            }
          },
          "lifecycle": {
            "type": "string",
            "enum": [
              "public_cli",
              "make_only",
              "report_generator",
              "helper",
              "test_only",
              "legacy_delete",
              "unclassified"
            ]
          },
          "install_state": {
            "type": "string",
            "enum": [
              "public_cli",
              "transitional_installed",
              "not_installed",
              "unclassified"
            ]
          },
          "console_scripts": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "direct_fallback": {
            "type": "boolean"
          },
          "make_targets": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "replacement": {
            "type": "string"
          },
          "removal_ready": {
            "type": "boolean"
          }
        }
      }
    },
    "unresolved_modules": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "unclassified_modules": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
