    "status_v2": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "migration_readiness_status",
        "compatibility_status_field",
        "compatibility_status_value",
        "compatibility_status_deprecated",
        "compatibility_alias_retention",
        "status_axes",
        "release_authority_status_field",
        "release_authority_status_value",
        "semantic_release_status_field",
        "semantic_release_status_value",
        "sealed_status_field",
        "sealed_status_value",
        "proposed_top_level_status_replacement",
        "status_classification",
        "authority_reason_ids",
        "sealed_reason_ids",
        "blocker_reason_ids",
        "recommended_consumer_fields",
        "summary"
      ],
      "properties": {
        "schema_version": { "type": "integer", "const": 2 },
        "migration_readiness_status": {
          "type": "string",
          "const": "active"
        },
        "compatibility_status_field": {
          "type": "string",
          "const": "status"
        },
        "compatibility_status_value": {
          "type": "string",
          "enum": ["pass", "fail"]
        },
        "compatibility_status_deprecated": { "type": "boolean", "const": true },
        "compatibility_alias_retention": {
          "type": "string",
          "const": "one_to_two_releases"
        },
        "status_axes": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "release_authority_status",
            "semantic_release_status",
            "sealed_release_status"
          ],
          "properties": {
            "release_authority_status": { "type": "string", "minLength": 1 },
            "semantic_release_status": { "type": "string", "minLength": 1 },
            "sealed_release_status": { "type": "string", "minLength": 1 }
          }
        },
        "release_authority_status_field": {
          "type": "string",
          "const": "release_authority_status"
        },
        "release_authority_status_value": { "type": "string", "minLength": 1 },
        "semantic_release_status_field": {
          "type": "string",
          "const": "semantic_release_status"
        },
        "semantic_release_status_value": { "type": "string", "minLength": 1 },
        "sealed_status_field": {
          "type": "string",
          "const": "sealed_release_status"
        },
        "sealed_status_value": { "type": "string", "minLength": 1 },
        "proposed_top_level_status_replacement": {
          "type": "string",
          "const": "sealed_release_status"
        },
        "status_classification": {
          "type": "string",
          "enum": [
            "strict_clean_and_sealed",
            "semantic_clean_unsealed",
            "conditional_release",
            "blocked_or_unknown"
          ]
        },
        "authority_reason_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/release_authority_reason_id" }
        },
        "sealed_reason_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/release_authority_reason_id" }
        },
        "blocker_reason_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/release_authority_reason_id" }
        },
        "recommended_consumer_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "release_authority_status",
              "sealed_release_status",
              "release_authority_vocabulary.blocker_reason_ids"
            ]
          }
        },
        "summary": { "type": "string", "minLength": 1 }
      }
    },
    "release_authority_vocabulary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "release_authority_status",
        "semantic_release_status",
        "sealed_release_status",
        "machine_release_allowed",
        "clean_release_ready",
        "batch_integrity_status",
        "distribution_package_status",
        "authority_reason_ids",
        "sealed_reason_ids",
        "blocker_reason_ids",
        "operator_summary",
        "operator_summary_round_trip",
        "summary"
      ],
      "properties": {
        "schema_version": { "type": "integer", "minimum": 1 },
        "release_authority_status": {
          "type": "string",
          "enum": ["clean_pass", "conditional_pass", "blocked", "unknown"]
        },
        "semantic_release_status": {
          "type": "string",
          "enum": ["clean_pass", "conditional_pass", "blocked", "unknown"]
        },
        "sealed_release_status": {
          "type": "string",
          "enum": [
            "sealed_clean_pass",
            "sealed_conditional_pass",
            "unsealed_artifact_incomplete",
            "unsealed_distribution_not_provided",
            "unsealed_distribution_invalid",
            "unsealed_distribution_drift",
            "unsealed_release_blocked"
          ]
        },
        "machine_release_allowed": { "type": "boolean" },
        "clean_release_ready": { "type": "boolean" },
        "batch_integrity_status": { "type": "string", "enum": ["pass", "fail"] },
        "distribution_package_status": { "type": "string", "minLength": 1 },
        "authority_reason_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/release_authority_reason_id" }
        },
        "sealed_reason_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/release_authority_reason_id" }
        },
        "blocker_reason_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/release_authority_reason_id" }
        },
        "operator_summary": { "type": "string", "minLength": 1 },
        "operator_summary_round_trip": {
          "$ref": "#/$defs/release_authority_operator_summary_round_trip"
        },
        "summary": { "type": "string", "minLength": 1 }
      }
    },
