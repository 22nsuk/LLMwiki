      "type": "object",
      "additionalProperties": false,
      "required": [
        "release_authority_status",
        "semantic_release_status",
        "sealed_release_status",
        "machine_release_allowed",
        "clean_release_ready",
        "batch_integrity_status",
        "distribution_package_status",
        "authority_reason_ids",
        "sealed_reason_ids",
        "blocker_reason_ids"
      ],
      "properties": {
        "release_authority_status": {
          "type": "string",
          "enum": ["clean_pass", "conditional_pass", "blocked", "unknown"]
        },
        "semantic_release_status": {
          "type": "string",
          "enum": ["clean_pass", "conditional_pass", "blocked", "unknown"]
        },
        "sealed_release_status": {
          "type": "string",
          "enum": [
            "sealed_clean_pass",
            "sealed_conditional_pass",
            "unsealed_artifact_incomplete",
            "unsealed_distribution_not_provided",
            "unsealed_distribution_invalid",
            "unsealed_distribution_drift",
            "unsealed_release_blocked"
          ]
        },
        "machine_release_allowed": { "type": "boolean" },
        "clean_release_ready": { "type": "boolean" },
        "batch_integrity_status": { "type": "string", "enum": ["pass", "fail"] },
        "distribution_package_status": { "type": "string", "minLength": 1 },
        "authority_reason_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/release_authority_reason_id" }
        },
        "sealed_reason_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/release_authority_reason_id" }
        },
        "blocker_reason_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/release_authority_reason_id" }
        }
      }
    },
    "release_authority_operator_summary_round_trip": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "parser",
        "expected",
        "parsed",
        "mismatch_count",
        "mismatches"
      ],
      "properties": {
        "status": { "type": "string", "enum": ["pass", "fail"] },
        "parser": {
          "type": "string",
          "const": "release_authority_operator_summary_v1"
        },
        "expected": {
          "$ref": "#/$defs/release_authority_operator_summary_decision"
        },
        "parsed": {
          "$ref": "#/$defs/release_authority_operator_summary_decision"
        },
        "mismatch_count": { "type": "integer", "minimum": 0 },
        "mismatches": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["field", "expected", "actual"],
            "properties": {
              "field": {
                "type": "string",
                "enum": [
                  "release_authority_status",
                  "semantic_release_status",
                  "sealed_release_status",
                  "machine_release_allowed",
                  "clean_release_ready",
                  "batch_integrity_status",
                  "distribution_package_status",
                  "authority_reason_ids",
                  "sealed_reason_ids",
                  "blocker_reason_ids"
                ]
              },
              "expected": { "type": "string" },
              "actual": { "type": "string" }
            }
          }
        }
      }
    },
    "optional_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "path",
        "sha256",
        "size_bytes",
        "required",
        "include_in_default_pack",
        "source",
        "status"
      ],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^(|[a-f0-9]{64})$" },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "required": { "type": "boolean" },
        "include_in_default_pack": { "type": "boolean" },
        "source": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["available", "missing_or_mismatch"] }
      }
    }
