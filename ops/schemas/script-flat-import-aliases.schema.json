{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LLM Wiki Script Flat Import Aliases",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "version",
    "description",
    "aliases"
  ],
  "properties": {
    "$schema": {
      "const": "ops/schemas/script-flat-import-aliases.schema.json"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "aliases": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/flatImportAlias"
      }
    }
  },
  "$defs": {
    "flatImportAlias": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonical_module"
      ],
      "properties": {
        "canonical_module": {
          "type": "string",
          "pattern": "^ops\\.scripts(\\.[A-Za-z0-9_]+)+$"
        }
      }
    }
  }
}
