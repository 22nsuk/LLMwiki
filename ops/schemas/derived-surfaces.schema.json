{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LLM Wiki Derived Surfaces Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "version",
    "description",
    "generated_make_fragment",
    "aggregate",
    "surfaces"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "ops/schemas/derived-surfaces.schema.json"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "description": {
      "$ref": "#/$defs/non_empty_string"
    },
    "generated_make_fragment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "generator_module"],
      "properties": {
        "path": {
          "$ref": "#/$defs/path"
        },
        "generator_module": {
          "$ref": "#/$defs/python_module"
        }
      }
    },
    "aggregate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sync_target",
        "check_target",
        "internal_sync_target",
        "internal_check_target"
      ],
      "properties": {
        "sync_target": {
          "$ref": "#/$defs/make_target"
        },
        "check_target": {
          "$ref": "#/$defs/make_target"
        },
        "internal_sync_target": {
          "$ref": "#/$defs/make_target"
        },
        "internal_check_target": {
          "$ref": "#/$defs/make_target"
        }
      }
    },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/surface"
      }
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
    },
    "python_module": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*(\\.[A-Za-z_][A-Za-z0-9_]*)*$"
    },
    "make_target": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-][A-Za-z0-9_.-]*$"
    },
    "surface_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "surface_kind": {
      "type": "string",
      "enum": [
        "managed_block",
        "generated_make_fragment",
        "managed_policy_projection",
        "tracked_json",
        "tracked_fixture",
        "local_report",
        "diagnostic"
      ]
    },
    "path_list": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/path"
      },
      "uniqueItems": true
    },
    "optional_path_list": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/path"
      },
      "uniqueItems": true
    },
    "surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_id",
        "description",
        "kind",
        "sync_target",
        "check_target",
        "generator_module",
        "source_paths",
        "tracked_outputs",
        "local_outputs",
        "include_in_sync_derived"
      ],
      "properties": {
        "surface_id": {
          "$ref": "#/$defs/surface_id"
        },
        "description": {
          "$ref": "#/$defs/non_empty_string"
        },
        "kind": {
          "$ref": "#/$defs/surface_kind"
        },
        "sync_target": {
          "$ref": "#/$defs/make_target"
        },
        "check_target": {
          "$ref": "#/$defs/make_target"
        },
        "generator_module": {
          "$ref": "#/$defs/python_module"
        },
        "source_paths": {
          "$ref": "#/$defs/path_list"
        },
        "tracked_outputs": {
          "$ref": "#/$defs/optional_path_list"
        },
        "local_outputs": {
          "$ref": "#/$defs/optional_path_list"
        },
        "include_in_sync_derived": {
          "type": "boolean"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
