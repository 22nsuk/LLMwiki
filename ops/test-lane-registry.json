{
  "$schema": "ops/schemas/test-lane-registry.schema.json",
  "version": 2,
  "description": "Authoritative registry for persistent pytest lanes, derived execution packs, CI routing, and documentation boundaries used by Make, CI, and public-safe docs.",
  "persistent_lanes": [
    {
      "lane_id": "slow",
      "marker": "slow",
      "authority": "persistent",
      "semantics": "Expensive deterministic runtime tests excluded from the default fast lane.",
      "ci_tier": "slow",
      "ci_entrypoint": "test-slow",
      "ci_steps": [
        "make test-slow"
      ],
      "make_target": "test-slow",
      "allowed_markers": [],
      "forbidden_markers": [
        "integration",
        "integration_heavy",
        "public"
      ],
      "selection": {
        "mode": "marker_expression",
        "pytest_mark_expr": "slow and not integration and not integration_heavy and not public"
      }
    },
    {
      "lane_id": "integration",
      "marker": "integration",
      "authority": "persistent",
      "semantics": "End-to-end or live-runtime contract tests in the standard integration tier.",
      "ci_tier": "integration",
      "ci_entrypoint": "test-integration",
      "ci_steps": [
        "make test-integration"
      ],
      "make_target": "test-integration",
      "allowed_markers": [
        "report_contract"
      ],
      "forbidden_markers": [
        "integration_heavy",
        "public"
      ],
      "selection": {
        "mode": "marker_expression",
        "pytest_mark_expr": "integration and not integration_heavy and not public"
      }
    },
    {
      "lane_id": "integration_heavy",
      "marker": "integration_heavy",
      "authority": "persistent",
      "semantics": "Heavier live generation tests that run separately and are not implied by plain integration.",
      "ci_tier": "integration-heavy",
      "ci_entrypoint": "test-integration-heavy",
      "ci_steps": [
        "make test-integration-heavy"
      ],
      "make_target": "test-integration-heavy",
      "allowed_markers": [
        "report_contract"
      ],
      "forbidden_markers": [
        "public"
      ],
      "selection": {
        "mode": "marker_expression",
        "pytest_mark_expr": "integration_heavy and not public"
      }
    },
    {
      "lane_id": "public",
      "marker": "public",
      "authority": "persistent",
      "semantics": "Public-surface contract tests for root-tree and exported-tree checks.",
      "ci_tier": "public",
      "ci_entrypoint": "public-check",
      "ci_steps": [
        "make public-check"
      ],
      "make_target": "test-public",
      "allowed_markers": [
        "report_contract",
        "release_sealing"
      ],
      "forbidden_markers": [],
      "selection": {
        "mode": "marker_expression",
        "pytest_mark_expr": "public"
      }
    },
    {
      "lane_id": "report_contract",
      "marker": "report_contract",
      "authority": "persistent",
      "semantics": "Report, schema, template, and generated artifact contract tests.",
      "ci_tier": "report-contract",
      "ci_entrypoint": "test-report-contract",
      "ci_steps": [
        "make test-report-contract",
        "make external-report-reference-manifest-release-check"
      ],
      "make_target": "test-report-contract",
      "allowed_markers": [
        "public",
        "integration",
        "integration_heavy",
        "artifact_finalization"
      ],
      "forbidden_markers": [],
      "selection": {
        "mode": "marker_expression",
        "pytest_mark_expr": "report_contract and not artifact_finalization"
      }
    },
    {
      "lane_id": "artifact_finalization",
      "marker": "artifact_finalization",
      "authority": "persistent",
      "semantics": "Checked-in generated artifact self-checks that run after producer closeout refresh.",
      "ci_tier": "artifact-finalization",
      "ci_entrypoint": "test-artifact-finalization",
      "ci_steps": [
        "make test-artifact-finalization"
      ],
      "make_target": "test-artifact-finalization",
      "allowed_markers": [
        "report_contract"
      ],
      "forbidden_markers": [],
      "selection": {
        "mode": "marker_expression",
        "pytest_mark_expr": "artifact_finalization"
      }
    },
    {
      "lane_id": "release_sealing",
      "marker": "release_sealing",
      "authority": "persistent",
      "semantics": "Release-builder sealing, batch manifest, and final artifact immutability checks.",
      "ci_tier": "release-sealing",
      "ci_entrypoint": "test-release-sealing",
      "ci_steps": [
        "make test-release-sealing"
      ],
      "make_target": "test-release-sealing",
      "allowed_markers": [
        "public"
      ],
      "forbidden_markers": [],
      "selection": {
        "mode": "marker_expression",
        "pytest_mark_expr": "release_sealing"
      }
    },
    {
      "lane_id": "process_boundary_runtime_behavior",
      "marker": "subprocess",
      "authority": "persistent",
      "semantics": "Tests that exercise real subprocess, interpreter startup, timeout, or OS command behavior.",
      "ci_tier": "subprocess",
      "ci_entrypoint": "test-subprocess",
      "ci_steps": [
        "make test-subprocess"
      ],
      "make_target": "test-subprocess",
      "allowed_markers": [],
      "forbidden_markers": [],
      "selection": {
        "mode": "marker_expression",
        "pytest_mark_expr": "subprocess"
      }
    }
  ],
  "derived_packs": [
    {
      "pack_id": "fast",
      "authority": "derived",
      "status": "derived_from_registry",
      "semantics": "Default fast lane derived as the complement of persistent authoritative lanes.",
      "backing_targets": [
        "test-fast",
        "unit-tests",
        "test"
      ],
      "selection": {
        "mode": "marker_expression",
        "pytest_mark_expr": "not slow and not integration and not integration_heavy and not public and not report_contract and not artifact_finalization and not release_sealing and not subprocess"
      },
      "summary_suite": {
        "suite_id": "fast",
        "suite_scope": "fast_unit",
        "summary_target": "ops/reports/test-execution-summary-fast.json",
        "make_summary_target": "test-execution-summary-fast"
      },
      "ci_entrypoint": "test-fast",
      "ci_steps": [
        "make static",
        "make test-fast"
      ],
      "documented_entrypoints": [
        "make test-fast",
        "make test",
        "make unit-tests"
      ]
    },
    {
      "pack_id": "fast_smoke",
      "authority": "advisory",
      "status": "derived_from_registry",
      "semantics": "Curated developer precheck slice for fast feedback.",
      "backing_targets": [
        "fast-smoke"
      ],
      "selection": {
        "mode": "explicit_selectors",
        "pytest_mark_expr": "not slow and not integration_heavy",
