{
  "$schema": "ops/schemas/test-lane-registry.schema.json",
  "version": 2,
  "description": "Authoritative registry for persistent pytest lanes, derived execution packs, CI routing, and documentation boundaries validated against Make, CI, and public-safe docs.",
  "trusted_ci_evidence": {
    "status": "additive_non_authoritative",
    "repository": "22nsuk/LLMwiki",
    "signer_workflow": "22nsuk/LLMwiki/.github/workflows/release.yml",
    "workflow_path": ".github/workflows/release.yml",
    "runner": "ubuntu-latest",
    "summary_suite": "full",
    "semantic_command": "aggregate test execution summary shards",
    "environment": {
      "python_major_minor": "3.12",
      "minimum_pytest_major": 8,
      "plugin_autoload_disabled": true,
      "interpreter_path_class": "repo_virtualenv",
      "toolchain_status": "pass",
      "release_evidence_effect": "eligible"
    }
  },
  "changed_path_minimums": {
    "version": 1,
    "default_duration_budget_seconds": 300,
    "final_checkpoint_commands": [
      "make release-run-ready"
    ],
    "command_duration_seconds": {
      "make static": 60,
      "make test": 150,
      "make test-fast": 120,
      "make test-boundary-contract-smoke": 30,
      "PYTHONDONTWRITEBYTECODE=1 .venv/bin/python -m pytest -q -p no:cacheprovider {path}": 30,
      "PYTHONDONTWRITEBYTECODE=1 .venv/bin/python -m pytest -q -p no:cacheprovider tests/test_changed_path_minimum_executor.py": 30,
      "PYTHONDONTWRITEBYTECODE=1 .venv/bin/python -m pytest -q -p no:cacheprovider tests/test_workflow_dependency_planner.py": 30,
      "PYTHONDONTWRITEBYTECODE=1 .venv/bin/python -m pytest -q -p no:cacheprovider tests/test_source_revision_runtime.py": 30,
      "PYTHONDONTWRITEBYTECODE=1 .venv/bin/python -m pytest -q -p no:cacheprovider tests/test_release_workflow_static.py": 30,
      "PYTHONDONTWRITEBYTECODE=1 .venv/bin/python -m pytest -q -p no:cacheprovider tests/test_derived_surfaces.py": 30,
      "make makefile-static-gates": 210,
      "make test-execution-summary-current-or-refresh": 180,
      "make workflow-dependency-planner-check": 60,
      "make runtime-hotspot-smoke": 240,
      "make test-executor-runtime": 120,
      "make sync-derived-check": 120,
      "make report-schema-samples-check": 30,
      "make public-check": 120
    },
    "unknown_path": {
      "rule_id": "unknown_path",
      "commands": [
        "make static",
        "make test"
      ],
      "reason": "Unknown paths use the conservative advisory minimum lane.",
      "coverage_class": "conservative",
      "static_required": true,
      "duration_seconds": 300
    },
    "rules": [
      {
        "rule_id": "runtime_hotspot_source",
        "path_patterns": [
          "ops/scripts/mechanism/auto_improve*_runtime.py",
          "ops/scripts/mechanism/mutation_proposal*_runtime.py",
          "ops/scripts/mechanism/next_run_repair_queue_runtime.py",
          "ops/scripts/mechanism/goal_runtime_run_admission.py",
          "ops/scripts/release/release_evidence_dashboard.py",
          "ops/scripts/release/release_evidence_dashboard*_runtime.py"
        ],
        "commands": [
          "make static",
          "make runtime-hotspot-smoke"
        ],
        "reason": "Runtime hotspot façade and helper changes need the focused hotspot smoke lane, including slow golden coverage that the generic fast lane excludes.",
        "coverage_class": "runtime_hotspot",
        "static_required": true,
        "duration_seconds": 300
      },
      {
        "rule_id": "report_schema_sample_generator",
        "path_patterns": [
          "tools/regenerate_report_schema_samples.py",
          "tests/fixtures/report_schema_sample*.json",
          "tests/report_contract_test_runtime.py",
          "tests/release_run_ready_sample_runtime.py",
          "tests/supply_chain_sample_runtime.py"
        ],
        "commands": [
          "make static",
          "make report-schema-samples-check",
          "PYTHONDONTWRITEBYTECODE=1 .venv/bin/python -m pytest -q -p no:cacheprovider tests/test_report_schema_sample_regeneration.py",
          "make test-execution-summary-current-or-refresh"
        ],
        "reason": "Report schema sample generator and helper changes need static analysis, seed-backed generation checks, focused generator coverage, and schema-contract validation.",
        "coverage_class": "report_schema_sample_generation",
        "static_required": true,
        "duration_seconds": 300
      },
      {
        "rule_id": "compatibility_alias_policy_source",
        "path_patterns": [
          "ops/scripts/_compatibility_alias_policy.py"
        ],
        "commands": [
          "make static",
          "PYTHONDONTWRITEBYTECODE=1 .venv/bin/python -m pytest -q -p no:cacheprovider tests/test_compatibility_alias_deprecation.py"
        ],
        "reason": "Compatibility alias retention policy changes should validate the focused alias deprecation contract instead of falling through to an unknown path advisory.",
        "coverage_class": "compatibility_alias_policy",
        "static_required": true,
        "duration_seconds": 90
      },
      {
        "rule_id": "git_runtime_shared_source",
        "path_patterns": [
          "ops/scripts/core/git_runtime.py"
        ],
        "commands": [
          "make static",
          "make workflow-dependency-planner-check",
          "PYTHONDONTWRITEBYTECODE=1 .venv/bin/python -m pytest -q -p no:cacheprovider tests/test_workflow_dependency_planner.py",
          "PYTHONDONTWRITEBYTECODE=1 .venv/bin/python -m pytest -q -p no:cacheprovider tests/test_source_revision_runtime.py"
        ],
        "reason": "Trusted Git runtime changes affect both workflow changed-path detection and source revision resolution, so both focused contracts should run.",
        "coverage_class": "git_runtime_shared",
        "static_required": true,
        "duration_seconds": 180
      },
      {
        "rule_id": "workflow_dependency_planner_source",
        "path_patterns": [
          "ops/scripts/core/changed_path_minimum_plan_runtime.py",
          "ops/scripts/core/git_changed_paths_runtime.py",
          "ops/scripts/core/workflow_dependency_planner.py"
        ],
        "commands": [
          "make static",
          "make workflow-dependency-planner-check",
          "PYTHONDONTWRITEBYTECODE=1 .venv/bin/python -m pytest -q -p no:cacheprovider tests/test_workflow_dependency_planner.py"
        ],
        "reason": "Workflow dependency planner source changes need manifest-backed planner diagnostics and the focused planner contract test.",
        "coverage_class": "workflow_dependency_planner",
        "static_required": true,
        "duration_seconds": 150
      },
      {
        "rule_id": "makefile_static_helpers",
        "path_patterns": [
          "tests/makefile_static_helpers.py"
        ],
        "commands": [
          "make static",
          "make makefile-static-gates"
        ],
        "reason": "Shared Makefile static helper changes should replay every split Makefile static gate owner, not a generic unknown-path lane.",
        "coverage_class": "makefile_static_gates",
        "static_required": true,
        "duration_seconds": 270
      },
      {
        "rule_id": "changed_path_minimum_executor_source",
        "path_patterns": [
          "ops/scripts/test/changed_path_minimum_executor.py"
        ],
        "commands": [
          "make static",
          "PYTHONDONTWRITEBYTECODE=1 .venv/bin/python -m pytest -q -p no:cacheprovider tests/test_changed_path_minimum_executor.py"
        ],
        "reason": "Changed-path executor changes should prove the command grammar, registry ownership, failure stop, and final-checkpoint boundary without replaying the default suite.",
        "coverage_class": "changed_path_minimum_executor",
        "static_required": true,
        "duration_seconds": 90
      },
      {
        "rule_id": "executor_runtime_source",
        "path_patterns": [
          "ops/scripts/core/executor.py",
          "ops/scripts/core/executor_runtime.py",
          "ops/scripts/core/executor_runtime_*_runtime.py",
          "ops/scripts/core/executor_noop_runtime.py",
          "ops/scripts/core/trusted_candidate_runner.py",
          "ops/scripts/core/workspace_python_identity_runtime.py",
          "ops/scripts/core/codex_exec_*.py",
          "ops/scripts/core/codex_exec_*_runtime.py"
        ],
        "commands": [
          "make static",
          "make test-executor-runtime"
        ],
        "reason": "Executor runtime changes should run the focused executor lane instead of falling through to the generic default test lane.",
        "coverage_class": "executor_runtime",
        "static_required": true,
        "duration_seconds": 180
      },
      {
        "rule_id": "python_runtime_source",
        "path_patterns": [
          "ops/scripts/*.py",
          "ops/scripts/**/*.py",
          "tools/*.py",
          "tools/**/*.py"
        ],
        "commands": [
          "make static"
        ],
        "reason": "Generic runtime Python changes use static analysis for iterative feedback; changed test files and owner-specific rules add focused behavior checks, while the explicit final checkpoint retains broad release authority.",
        "coverage_class": "runtime_source",
        "static_required": true,
        "duration_seconds": 60
      },
      {
        "rule_id": "pytest_harness",
        "path_patterns": [
          "tests/conftest.py"
        ],
        "commands": [
          "make static",
          "make test"
        ],
        "reason": "Pytest harness changes affect collection and shared fixtures, so they need the default test lane rather than an unknown-path advisory.",
        "coverage_class": "pytest_harness",
        "static_required": true,
        "duration_seconds": 210
      },
      {
        "rule_id": "focused_pytest_file",
        "path_patterns": [
          "tests/test_*.py"
        ],
        "commands": [
          "make static",
          "PYTHONDONTWRITEBYTECODE=1 .venv/bin/python -m pytest -q -p no:cacheprovider {path}"
        ],
        "reason": "Changed tests should run directly with static checks; this is not a full-suite proof.",
        "coverage_class": "focused_test",
        "static_required": true,
        "duration_seconds": 90
      },
      {
        "rule_id": "derived_surfaces_manifest_contract",
        "path_patterns": [
          "ops/policies/derived-surfaces.json",
          "ops/schemas/derived-surfaces.schema.json"
        ],
        "commands": [
          "make static",
          "make sync-derived-check",
          "PYTHONDONTWRITEBYTECODE=1 .venv/bin/python -m pytest -q -p no:cacheprovider tests/test_derived_surfaces.py"
        ],
        "reason": "Derived-surface manifest or schema changes should validate aggregate currentness and the focused manifest generator contract.",
        "coverage_class": "derived_surfaces_manifest",
        "static_required": true,
        "duration_seconds": 210
      },
      {
        "rule_id": "schema_or_report_contract",
        "path_patterns": [
          "ops/schemas/*.schema.json",
          "ops/policies/*.json",
          "ops/policies/*.yaml"
        ],
        "commands": [
          "make static",
          "make test-execution-summary-current-or-refresh"
        ],
        "reason": "Schema or policy changes need report-contract coverage plus static checks.",
        "coverage_class": "report_contract",
        "static_required": true,
        "duration_seconds": 240
      },
      {
        "rule_id": "release_workflow_static_contract",
        "path_patterns": [
          ".github/workflows/release.yml"
        ],
        "commands": [
          "make static",
          "make workflow-dependency-planner-check",
          "PYTHONDONTWRITEBYTECODE=1 .venv/bin/python -m pytest -q -p no:cacheprovider tests/test_release_workflow_static.py"
        ],
        "reason": "Release workflow edits should run the dedicated static workflow contract without implying report-contract core promotion.",
        "coverage_class": "release_workflow_static",
        "static_required": true,
        "duration_seconds": 150
      },
      {
        "rule_id": "make_or_ci_contract",
        "path_patterns": [
          "Makefile",
          "mk/*.mk",
          ".github/workflows/*.yml",
          ".github/workflows/*.yaml"
        ],
        "commands": [
          "make static",
          "make workflow-dependency-planner-check"
        ],
        "reason": "Make or CI orchestration changes should refresh planner diagnostics before broader gates.",
        "coverage_class": "orchestration",
        "static_required": true,
        "duration_seconds": 120
      },
      {
        "rule_id": "public_docs_boundary",
        "path_patterns": [
          "docs/*.md",
          "docs/**/*.md",
          "ops/*.md",
          "AGENTS.md",
          "ARCHITECTURE.md",
          "README.md"
        ],
        "commands": [
          "make static",
          "make public-check"
        ],
        "reason": "Public documentation and boundary changes need static and public export checks.",
        "coverage_class": "public_boundary",
        "static_required": true,
        "duration_seconds": 180
      },
      {
        "rule_id": "test_lane_registry_contract",
        "path_patterns": [
          "ops/test-lane-registry.json"
        ],
        "commands": [
          "make static",
          "make sync-derived-check",
          "make workflow-dependency-planner-check",
          "PYTHONDONTWRITEBYTECODE=1 .venv/bin/python -m pytest -q -p no:cacheprovider tests/test_workflow_dependency_planner.py"
        ],
        "reason": "Test lane registry changes should validate derived projections, planner output, and focused planner behavior before broader gates.",
        "coverage_class": "orchestration",
        "static_required": true,
        "duration_seconds": 240
      }
    ]
  },
  "persistent_lanes": [
    {
      "lane_id": "slow",
      "marker": "slow",
      "authority": "persistent",
      "semantics": "Expensive deterministic runtime tests excluded from the default fast lane.",
      "ci_tier": "slow",
      "ci_entrypoint": "test-slow",
      "ci_steps": [
        "make test-slow"
      ],
      "make_target": "test-slow",
      "allowed_markers": [],
      "forbidden_markers": [
        "integration",
        "integration_heavy",
        "public"
      ],
      "selection": {
        "mode": "marker_expression",
        "pytest_mark_expr": "slow and not integration and not integration_heavy and not public"
      }
    },
    {
      "lane_id": "integration",
      "marker": "integration",
      "authority": "persistent",
      "semantics": "End-to-end or live-runtime contract tests in the standard integration tier.",
      "ci_tier": "integration",
      "ci_entrypoint": "test-integration",
      "ci_steps": [
        "make test-integration"
      ],
      "make_target": "test-integration",
      "allowed_markers": [
        "report_contract"
      ],
      "forbidden_markers": [
        "integration_heavy",
        "public"
      ],
      "selection": {
        "mode": "marker_expression",
        "pytest_mark_expr": "integration and not integration_heavy and not public"
      }
    },
    {
      "lane_id": "integration_heavy",
      "marker": "integration_heavy",
      "authority": "persistent",
      "semantics": "Heavier live generation tests that run separately and are not implied by plain integration.",
      "ci_tier": "integration-heavy",
      "ci_entrypoint": "test-integration-heavy",
      "ci_steps": [
        "make test-integration-heavy"
      ],
      "make_target": "test-integration-heavy",
      "allowed_markers": [
        "report_contract"
      ],
      "forbidden_markers": [
        "public"
      ],
      "selection": {
        "mode": "marker_expression",
        "pytest_mark_expr": "integration_heavy and not public"
      }
    },
    {
      "lane_id": "public",
      "marker": "public",
      "authority": "persistent",
      "semantics": "Public-surface contract tests for root-tree and exported-tree checks.",
      "ci_tier": "public",
      "ci_entrypoint": "ci-public-tier",
      "ci_steps": [
        "make ci-public-tier"
      ],
      "make_target": "test-public",
      "allowed_markers": [
        "report_contract",
        "release_sealing"
      ],
      "forbidden_markers": [],
      "selection": {
        "mode": "marker_expression",
        "pytest_mark_expr": "public"
      }
    },
    {
      "lane_id": "report_contract",
      "marker": "report_contract",
      "authority": "persistent",
      "semantics": "Report, schema, template, and generated artifact contract tests.",
      "ci_tier": "report-contract",
      "ci_entrypoint": "ci-report-contract-tier",
      "ci_steps": [
        "make ci-report-contract-tier"
      ],
      "make_target": "test-report-contract-all",
      "allowed_markers": [
        "public",
        "integration",
        "integration_heavy"
      ],
      "forbidden_markers": [],
      "selection": {
        "mode": "marker_expression",
        "pytest_mark_expr": "report_contract"
      }
    },
    {
      "lane_id": "release_sealing",
      "marker": "release_sealing",
      "authority": "persistent",
      "semantics": "Release-builder sealing, batch manifest, and final artifact immutability checks.",
      "ci_tier": "release-sealing",
      "ci_entrypoint": "test-release-sealing-all",
      "ci_steps": [
        "make test-release-sealing-all",
        "make -n release-run-ready",
        "make -n release-sealed-run-ready",
        "make -n release-auto-promotion-ready"
      ],
      "make_target": "test-release-sealing-all",
      "allowed_markers": [
        "public"
      ],
      "forbidden_markers": [],
      "selection": {
        "mode": "marker_expression",
        "pytest_mark_expr": "release_sealing"
      }
    },
    {
      "lane_id": "process_boundary_runtime_behavior",
      "marker": "subprocess",
      "authority": "persistent",
      "semantics": "Tests that exercise real subprocess, interpreter startup, timeout, or OS command behavior.",
      "ci_tier": "subprocess",
      "ci_entrypoint": "test-subprocess",
      "ci_steps": [
        "make test-subprocess"
      ],
      "make_target": "test-subprocess",
      "allowed_markers": [],
      "forbidden_markers": [],
      "selection": {
        "mode": "marker_expression",
        "pytest_mark_expr": "subprocess"
      }
    }
  ],
  "derived_packs": [
    {
      "pack_id": "fast",
      "authority": "derived",
      "status": "derived_from_registry",
      "semantics": "Default fast lane derived as the complement of persistent authoritative lanes.",
      "backing_targets": [
        "test-fast",
        "unit-tests",
        "test"
      ],
      "selection": {
        "mode": "marker_expression",
        "pytest_mark_expr": "not slow and not integration and not integration_heavy and not public and not report_contract and not release_sealing and not subprocess"
      },
      "summary_suite": {
        "suite_id": "fast",
        "suite_scope": "fast_unit",
        "summary_target": "ops/reports/test-execution-summary-fast.json",
        "make_summary_target": "test-execution-summary-fast"
      },
      "ci_entrypoint": "test-fast",
      "ci_steps": [
        "make static",
        "make test-fast"
      ],
      "documented_entrypoints": [
        "make test-fast",
        "make test",
        "make unit-tests"
      ]
    },
    {
      "pack_id": "fast_smoke",
      "authority": "advisory",
      "status": "derived_from_registry",
      "semantics": "Curated developer precheck slice for fast feedback.",
      "backing_targets": [
        "fast-smoke"
      ],
      "selection": {
        "mode": "marker_expression",
        "pytest_mark_expr": "fast_smoke"
      },
      "ci_entrypoint": "fast-smoke",
      "ci_steps": [
        "make fast-smoke"
      ],
      "documented_entrypoints": [
        "make fast-smoke"
      ]
    },
    {
      "pack_id": "default_test_boundary",
      "authority": "derived",
      "status": "derived_from_registry",
      "semantics": "Curated public/report_contract boundary checks chained into make test so script placement, lifecycle classification, and selector-registry drift fail before the full public lane.",
      "backing_targets": [
        "test-boundary-contract-smoke"
      ],
      "selection": {
        "mode": "marker_expression",
        "pytest_mark_expr": "default_test_boundary"
      },
      "ci_entrypoint": "test-boundary-contract-smoke",
      "ci_steps": [
        "make test-boundary-contract-smoke"
      ],
      "documented_entrypoints": [
        "make test",
        "make test-boundary-contract-smoke"
      ]
    },
    {
      "pack_id": "runtime_hotspot_smoke",
      "authority": "advisory",
      "status": "derived_from_registry",
      "semantics": "Focused runtime hotspot façade decomposition check for batch feedback before broader fast-lane replay.",
      "backing_targets": [
        "runtime-hotspot-smoke"
      ],
      "selection": {
        "mode": "marker_expression",
        "pytest_mark_expr": "runtime_hotspot_smoke"
      },
      "ci_entrypoint": "runtime-hotspot-smoke",
      "ci_steps": [
        "make runtime-hotspot-smoke"
      ],
      "documented_entrypoints": [
        "make runtime-hotspot-smoke"
      ]
    },
    {
      "pack_id": "executor_runtime",
      "authority": "advisory",
      "status": "derived_from_registry",
      "semantics": "Focused executor runtime lane for Codex executor orchestration, environment, prompt/report, and pipeline behavior.",
      "backing_targets": [
        "test-executor-runtime"
      ],
      "selection": {
        "mode": "explicit_selectors",
        "selectors": [
          "test-executor-runtime"
        ],
        "tests_argument": "tests/test_executor_runtime.py"
      },
      "ci_entrypoint": "test-executor-runtime",
      "ci_steps": [
        "make test-executor-runtime"
      ],
      "documented_entrypoints": [
        "make test-executor-runtime"
      ]
    },
    {
      "pack_id": "developer_full",
      "authority": "derived",
      "status": "derived_from_registry",
      "semantics": "Developer full regression suite for all current pytest tests.",
      "backing_targets": [
        "unit-tests-all",
        "unit-tests-all-serial",
        "unit-tests-all-parallel",
        "test-all",
        "test-all-serial",
        "test-all-parallel",
        "check-all",
        "check-all-serial"
      ],
      "selection": {
        "mode": "all"
      },
      "ci_entrypoint": "test-all",
      "ci_steps": [
        "make test-all"
      ],
      "documented_entrypoints": [
        "make test-all",
        "make check-all"
      ]
    },
    {
      "pack_id": "release_check_unit_complement",
      "authority": "derived",
      "status": "derived_from_registry",
      "semantics": "Release-check pytest complement that excludes report-contract tests already executed by the preflight summary.",
      "backing_targets": [
        "unit-tests-release-check"
      ],
      "selection": {
        "mode": "marker_expression",
        "pytest_mark_expr": "not report_contract"
      },
      "ci_entrypoint": "release-check",
      "ci_steps": [
        "make release-check"
      ],
      "documented_entrypoints": [
        "make release-check",
        "make release-check-all-surfaces"
      ]
    },
    {
      "pack_id": "report_contract_core",
      "authority": "derived",
      "status": "derived_from_registry",
      "semantics": "Targeted core verification slice for report-contract summary evidence.",
      "backing_targets": [
        "test-report-contract-core"
      ],
      "selection": {
        "mode": "marker_expression",
        "pytest_mark_expr": "report_contract_core"
      },
      "summary_suite": {
        "suite_id": "report-contract-summary",
        "suite_scope": "report_contract_summary",
        "summary_target": "ops/reports/test-execution-summary.json",
        "make_summary_target": "test-execution-summary-report-contract"
      },
      "ci_entrypoint": "test-report-contract-core",
      "ci_steps": [
        "make test-report-contract-core",
        "make external-report-reference-manifest-release-check"
      ],
      "documented_entrypoints": [
        "make test-report-contract-core",
        "make test-execution-summary",
        "make test-execution-summary-report-contract"
      ]
    },
    {
      "pack_id": "release_closeout_regression",
      "authority": "derived",
      "status": "derived_from_registry",
      "semantics": "Focused release closeout regression pack used by CI and finalizer diagnostics.",
      "backing_targets": [
        "test-release-closeout-regression-pack",
        "release-closeout-regression-dry-run"
      ],
      "selection": {
        "mode": "marker_expression",
