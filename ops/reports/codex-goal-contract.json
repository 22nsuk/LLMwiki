        "required_before_next_profile": "30m trial evidence plus 6h repeated improvement session evidence and current release/readiness blockers"
      },
      {
        "profile": "2d_candidate",
        "max_wall_clock_seconds": 172800,
        "max_proposals": 24,
        "max_consecutive_failures": 3,
        "required_before_next_profile": "6h ramp evidence plus 2d repeated improvement session evidence, resume, and backoff evidence"
      },
      {
        "profile": "5d_sustained",
        "max_wall_clock_seconds": 432000,
        "max_proposals": 60,
        "max_consecutive_failures": 3,
        "required_before_next_profile": "2d candidate evidence plus 5d repeated improvement session evidence and sealed authority clean pass"
      }
    ]
