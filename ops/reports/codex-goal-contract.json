  "contract_id": "auto-improve-goal",
  "objective": "Run a bounded self-improvement loop whose result is certified by current readiness, release, source-package, public-check, status, and session evidence.",
  "non_goals": [
    "Do not treat wall-clock duration as proof without the self-improvement loop certificate.",
    "Do not promote release, learning, or improvement claims while promotion blockers remain.",
