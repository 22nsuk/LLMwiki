{
  "$schema": "ops/schemas/script-lifecycle-overrides.schema.json",
  "version": 1,
  "description": "Manual lifecycle and replacement overrides applied to the source-derived script lifecycle policy.",
  "overrides": [
    {
      "canonical_module": "ops.scripts.core.backfill_historical_bootstrap_reports",
      "lifecycle": "helper"
    },
    {
      "canonical_module": "ops.scripts.core.executor",
      "lifecycle": "helper"
    },
    {
      "canonical_module": "ops.scripts.mechanism.auto_improve_loop",
      "replacement": "python -m ops.scripts.mechanism.auto_improve_loop"
    },
    {
      "canonical_module": "ops.scripts.mechanism.goal_runtime_certificate_report",
      "replacement": "make goal-runtime-certificate"
    },
    {
      "canonical_module": "ops.scripts.mechanism.planning_gate_validate",
      "replacement": ""
    },
    {
      "canonical_module": "ops.scripts.mechanism.run_mechanism_experiment",
      "replacement": ""
    },
    {
      "canonical_module": "ops.scripts.mechanism.set_mechanism_run_history",
      "lifecycle": "helper"
    },
    {
      "canonical_module": "ops.scripts.registry.raw_registry_shard_policy_sync",
      "lifecycle": "make_only"
    },
    {
      "canonical_module": "ops.scripts.release.freshness_owner_route_converge",
      "lifecycle": "make_only"
    },
    {
      "canonical_module": "ops.scripts.release.github_governance_live_drift",
      "replacement": "make collaboration-governance"
    },
    {
      "canonical_module": "ops.scripts.release.release_run_manifest",
      "replacement": "make release-run-ready-check"
    },
    {
      "canonical_module": "ops.scripts.release.release_status_surface",
      "replacement": ""
    },
    {
      "canonical_module": "ops.scripts.test.ci_tier_lane_bridge",
      "lifecycle": "test_only"
    },
    {
      "canonical_module": "ops.scripts.test.generate_release_governance_from_lane_registry",
      "lifecycle": "test_only",
      "replacement": "make release-governance-sync"
    },
    {
      "canonical_module": "ops.scripts.test.generate_pytest_ini_markers",
      "lifecycle": "test_only",
      "replacement": "make pytest-markers-sync"
    },
    {
      "canonical_module": "ops.scripts.test.generate_test_mk_selectors",
      "lifecycle": "test_only",
      "replacement": "make test-selectors-sync"
    },
    {
      "canonical_module": "ops.scripts.test.test_execution_summary",
      "lifecycle": "test_only",
      "replacement": "make test-execution-summary-current-check"
    }
  ]
}
